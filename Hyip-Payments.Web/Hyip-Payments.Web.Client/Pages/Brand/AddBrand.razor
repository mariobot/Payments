@page "/brand/add"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Brand - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/brand/list">Brands</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add Brand</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-award text-danger me-2"></i>
                        Add New Brand
                    </h2>
                    <p class="text-muted mb-0">Register a new brand or manufacturer</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-xl-6 mx-auto">
            <!-- Main Form Card -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>
                        Brand Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="@brand" OnValidSubmit="HandleValidSubmit" FormName="addBrandForm">
                        <DataAnnotationsValidator />

                        <!-- Brand Name -->
                        <div class="mb-4">
                            <label for="name" class="form-label fw-semibold">
                                <i class="bi bi-award text-danger me-2"></i>
                                Brand Name
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-tag-fill"></i>
                                </span>
                                <InputText id="name"
                                         class="form-control"
                                         @bind-Value="brand.Name"
                                         placeholder="e.g., Apple, Samsung, Nike" />
                            </div>
                            <ValidationMessage For="@(() => brand.Name)" class="text-danger small mt-1" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Official brand or manufacturer name
                            </small>
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            <label for="description" class="form-label fw-semibold">
                                <i class="bi bi-text-paragraph text-danger me-2"></i>
                                Description
                            </label>
                            <InputTextArea id="description"
                                          class="form-control"
                                          @bind-Value="brand.Description"
                                          rows="4"
                                          placeholder="Provide a brief description of the brand (optional)" />
                            <ValidationMessage For="@(() => brand.Description)" class="text-danger small mt-1" />
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Brief description of the brand
                                </small>
                                <small class="text-muted">
                                    @((brand.Description?.Length ?? 0))/500 characters
                                </small>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-outline-secondary px-4" @onclick="GoBack" disabled="@isSubmitting">
                                <i class="bi bi-x-circle me-2"></i>
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-danger px-4" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Adding...</span>
                                }
                                else
                                {
                                    <i class="bi bi-plus-circle me-2"></i>
                                    <span>Add Brand</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

            <!-- Success/Error Messages -->
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show mt-4 shadow-sm" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div class="flex-grow-1">
                            <strong>Success!</strong>
                            <p class="mb-0">@successMessage</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-4 shadow-sm" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div class="flex-grow-1">
                            <strong>Error!</strong>
                            <p class="mb-0">@errorMessage</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
                </div>
            }

            <!-- Popular Brands Card -->
            <div class="card border-danger mt-4">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-star-fill text-danger me-2"></i>
                        Popular Brand Examples
                    </h6>
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Tech:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>🍎 Apple</li>
                                <li>📱 Samsung</li>
                                <li>💻 Microsoft</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <strong>Fashion:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>👟 Nike</li>
                                <li>👕 Adidas</li>
                                <li>👗 Zara</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <strong>Automotive:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>🚗 Tesla</li>
                                <li>🏎️ BMW</li>
                                <li>🚙 Toyota</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tips Card -->
            <div class="card border-info mt-4">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-lightbulb text-info me-2"></i>
                        Tips for Brand Management
                    </h6>
                    <ul class="mb-0 small">
                        <li>Use official brand names for consistency</li>
                        <li>Include relevant industry or category information</li>
                        <li>Keep descriptions concise but informative</li>
                        <li>Verify spelling and capitalization</li>
                        <li>Link brands to products for better organization</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Styles -->
<style>
    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .form-control:focus,
    .input-group:focus-within .input-group-text {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.15);
    }

    .input-group-text {
        transition: all 0.2s ease;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
        transition: color 0.2s ease;
    }

    .breadcrumb-item a:hover {
        color: #dc3545;
    }

    .btn {
        transition: all 0.2s ease;
    }

    .btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .alert {
        border-left: 4px solid;
    }

    .alert-success {
        border-left-color: #198754;
    }

    .alert-danger {
        border-left-color: #dc3545;
    }
</style>

@code {
    private BrandModel brand = new();
    private bool isSubmitting = false;
    private string? successMessage;
    private string? errorMessage;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Brand", brand);

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<BrandModel>();
                successMessage = $"Brand '{created?.Name}' added successfully!";

                // Reset form
                brand = new BrandModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/brand/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to add brand: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding brand: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/brand/list");
    }
}

