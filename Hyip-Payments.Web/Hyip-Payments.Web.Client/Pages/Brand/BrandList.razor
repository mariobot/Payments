@page "/brand/list"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Brands - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Brands</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-award text-danger me-2"></i>
                        Brands
                    </h2>
                    <p class="text-muted mb-0">Manage product brands and manufacturers</p>
                </div>
                <div>
                    <a href="/brand/add" class="btn btn-danger">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Brand
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Brands</h6>
                            <h3 class="mb-0">@(filteredBrands?.Count ?? 0)</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-award text-danger" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Active</h6>
                            <h3 class="mb-0">@(brands?.Count(b => b.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Inactive</h6>
                            <h3 class="mb-0">@(brands?.Count(b => !b.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-x-circle-fill text-secondary" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Showing</h6>
                            <h3 class="mb-0">@paginatedBrands.Count</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-eye-fill text-info" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0" 
                               placeholder="Search brands..." 
                               @bind="searchTerm" 
                               @bind:event="oninput"
                               @onkeyup="ApplyFilters" />
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="active">Active Only</option>
                        <option value="inactive">Inactive Only</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="pageSize" @bind:after="ApplyFilters">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-outline-success w-100" @onclick="ExportToCSV" disabled="@isLoading">
                        <i class="bi bi-file-earmark-excel me-2"></i>
                        Export CSV
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    @if (isLoading)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-danger mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mb-0">Loading brands...</p>
            </div>
        </div>
    }
    else if (brands == null || !brands.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-award text-muted mb-3" style="font-size: 4rem;"></i>
                <h4>No Brands Found</h4>
                <p class="text-muted mb-4">Start by adding your first brand</p>
                <a href="/brand/add" class="btn btn-danger">
                    <i class="bi bi-plus-circle me-2"></i>
                    Add Your First Brand
                </a>
            </div>
        </div>
    }
    else if (!paginatedBrands.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-search text-muted mb-3" style="font-size: 4rem;"></i>
                <h4>No Results Found</h4>
                <p class="text-muted mb-4">Try adjusting your search or filters</p>
                <button class="btn btn-outline-danger" @onclick="ClearFilters">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>
                    Clear Filters
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4" style="width: 50px;">
                                    <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" />
                                </th>
                                <th class="sortable" @onclick="() => SortBy(nameof(BrandModel.Name))">
                                    Brand Name
                                    @if (sortColumn == nameof(BrandModel.Name))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th>Description</th>
                                <th class="sortable" @onclick="() => SortBy(nameof(BrandModel.IsActive))">
                                    Status
                                    @if (sortColumn == nameof(BrandModel.IsActive))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th class="text-end px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var brand in paginatedBrands)
                            {
                                <tr>
                                    <td class="px-4">
                                        <input type="checkbox" 
                                               class="form-check-input" 
                                               @bind="brand.IsSelected" />
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-danger bg-opacity-10 rounded-circle p-2 me-3">
                                                <i class="bi bi-award-fill text-danger"></i>
                                            </div>
                                            <div>
                                                <strong>@brand.Name</strong>
                                                <br />
                                                <small class="text-muted">ID: #@brand.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(brand.Description))
                                        {
                                            <span class="text-muted">
                                                @(brand.Description.Length > 100 ? brand.Description.Substring(0, 100) + "..." : brand.Description)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">No description</span>
                                        }
                                    </td>
                                    <td>
                                        @if (brand.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle me-1"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="btn-group" role="group">
                                            <a href="/brand/edit/@brand.Id" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBrand(brand.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <div class="card-footer bg-light">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="mb-0 text-muted">
                            Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, filteredBrands.Count) 
                            of @filteredBrands.Count entries
                        </p>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                                </li>
                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bulk Actions -->
        @if (brands.Any(b => b.IsSelected))
        {
            <div class="card border-0 shadow-sm mt-3 border-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@brands.Count(b => b.IsSelected) item(s) selected</strong>
                        </div>
                        <div class="btn-group">
                            <button class="btn btn-outline-success btn-sm" @onclick="BulkActivate">
                                <i class="bi bi-check-circle me-1"></i> Activate
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="BulkDeactivate">
                                <i class="bi bi-x-circle me-1"></i> Deactivate
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="BulkDelete">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }
</div>

<style>
    .sortable {
        cursor: pointer;
        user-select: none;
    }

    .sortable:hover {
        background-color: rgba(0, 0, 0, 0.05);
    }

    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }

    .btn-group .btn {
        padding: 0.25rem 0.5rem;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
    }

    .breadcrumb-item a:hover {
        color: #dc3545;
    }
</style>

@code {
    private List<BrandModel> brands = new();
    private List<BrandModel> filteredBrands = new();
    private List<BrandModel> paginatedBrands = new();

    private bool isLoading = true;
    private string? errorMessage;

    private string searchTerm = "";
    private string statusFilter = "";

    private string sortColumn = nameof(BrandModel.Name);
    private bool sortDescending = false;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling(filteredBrands.Count / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadBrands();
    }

    private async Task LoadBrands()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await Http.GetFromJsonAsync<List<BrandModel>>("api/Brand");
            brands = result ?? new List<BrandModel>();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading brands: {ex.Message}";
            brands = new List<BrandModel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredBrands = brands.Where(b =>
            (string.IsNullOrEmpty(searchTerm) || 
             b.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             (b.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) &&
            (statusFilter == "" || 
             (statusFilter == "active" && b.IsActive) || 
             (statusFilter == "inactive" && !b.IsActive))
        ).ToList();

        ApplySorting();
        currentPage = 1;
        UpdatePagination();
    }

    private void ApplySorting()
    {
        filteredBrands = sortColumn switch
        {
            nameof(BrandModel.Name) => sortDescending 
                ? filteredBrands.OrderByDescending(b => b.Name).ToList()
                : filteredBrands.OrderBy(b => b.Name).ToList(),
            nameof(BrandModel.IsActive) => sortDescending
                ? filteredBrands.OrderByDescending(b => b.IsActive).ToList()
                : filteredBrands.OrderBy(b => b.IsActive).ToList(),
            _ => filteredBrands
        };
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }
        ApplySorting();
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        paginatedBrands = filteredBrands
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            UpdatePagination();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        ApplyFilters();
    }

    private void ClearFilters()
    {
        searchTerm = "";
        statusFilter = "";
        ApplyFilters();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        foreach (var brand in paginatedBrands)
        {
            brand.IsSelected = isChecked;
        }
    }

    private async Task DeleteBrand(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this brand?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Brand/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await LoadBrands();
                }
                else
                {
                    errorMessage = "Failed to delete brand.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting brand: {ex.Message}";
            }
        }
    }

    private async Task BulkActivate()
    {
        var selected = brands.Where(b => b.IsSelected).ToList();
        foreach (var brand in selected)
        {
            brand.IsActive = true;
            await Http.PutAsJsonAsync($"api/Brand/{brand.Id}", brand);
        }
        await LoadBrands();
    }

    private async Task BulkDeactivate()
    {
        var selected = brands.Where(b => b.IsSelected).ToList();
        foreach (var brand in selected)
        {
            brand.IsActive = false;
            await Http.PutAsJsonAsync($"api/Brand/{brand.Id}", brand);
        }
        await LoadBrands();
    }

    private async Task BulkDelete()
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete {brands.Count(b => b.IsSelected)} brands?"))
        {
            var selected = brands.Where(b => b.IsSelected).ToList();
            foreach (var brand in selected)
            {
                await Http.DeleteAsync($"api/Brand/{brand.Id}");
            }
            await LoadBrands();
        }
    }

    private async Task ExportToCSV()
    {
        var csv = "ID,Name,Description,Status\n";
        foreach (var brand in filteredBrands)
        {
            csv += $"{brand.Id},\"{brand.Name}\",\"{brand.Description}\",\"{(brand.IsActive ? "Active" : "Inactive")}\"\n";
        }

        await JSRuntime.InvokeVoidAsync("downloadFile", "brands.csv", csv);
    }
}
