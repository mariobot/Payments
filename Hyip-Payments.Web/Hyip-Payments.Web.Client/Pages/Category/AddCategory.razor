@page "/category/add"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Category - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/category/list">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add Category</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-folder-plus text-primary me-2"></i>
                        Add New Category
                    </h2>
                    <p class="text-muted mb-0">Create a new category for organizing products</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-xl-6 mx-auto">
            <!-- Main Form Card -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>
                        Category Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="@category" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />

                        <!-- Category Name -->
                        <div class="mb-4">
                            <label for="name" class="form-label fw-semibold">
                                <i class="bi bi-tag text-primary me-2"></i>
                                Category Name
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-folder"></i>
                                </span>
                                <InputText id="name" 
                                           class="form-control form-control-lg" 
                                           @bind-Value="category.Name"
                                           placeholder="e.g., Electronics, Clothing, Food & Beverage" />
                            </div>
                            <ValidationMessage For="@(() => category.Name)" class="text-danger small mt-1" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Choose a clear, descriptive name for this category
                            </small>
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            <label for="description" class="form-label fw-semibold">
                                <i class="bi bi-text-paragraph text-primary me-2"></i>
                                Description
                            </label>
                            <InputTextArea id="description" 
                                          class="form-control" 
                                          @bind-Value="category.Description"
                                          rows="4"
                                          placeholder="Provide a brief description of this category (optional)" />
                            <ValidationMessage For="@(() => category.Description)" class="text-danger small mt-1" />
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Provide additional details about this category
                                </small>
                                <small class="text-muted">
                                    @((category.Description?.Length ?? 0))/500 characters
                                </small>
                            </div>
                        </div>

                        <!-- Active Status -->
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <InputCheckbox id="isActive" 
                                             class="form-check-input" 
                                             @bind-Value="category.IsActive" 
                                             style="width: 3em; height: 1.5em;" />
                                <label class="form-check-label fw-semibold ms-2" for="isActive">
                                    <i class="bi bi-toggle-on text-success me-2"></i>
                                    Active Category
                                </label>
                            </div>
                            <small class="form-text text-muted ms-5">
                                <i class="bi bi-info-circle"></i> Only active categories can be used for products
                            </small>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-outline-secondary px-4" @onclick="GoBack" disabled="@isSubmitting">
                                <i class="bi bi-x-circle me-2"></i>
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary px-4" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Creating...</span>
                                }
                                else
                                {
                                    <i class="bi bi-plus-circle me-2"></i>
                                    <span>Create Category</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

            <!-- Success/Error Messages -->
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show mt-4 shadow-sm" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div class="flex-grow-1">
                            <strong>Success!</strong>
                            <p class="mb-0">@successMessage</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-4 shadow-sm" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div class="flex-grow-1">
                            <strong>Error!</strong>
                            <p class="mb-0">@errorMessage</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
                </div>
            }

            <!-- Example Categories Card -->
            <div class="card border-primary mt-4">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-lightbulb text-primary me-2"></i>
                        Example Categories
                    </h6>
                    <div class="row">
                        <div class="col-md-4">
                            <ul class="list-unstyled mb-0 small">
                                <li><i class="bi bi-check-circle text-success"></i> Electronics</li>
                                <li><i class="bi bi-check-circle text-success"></i> Clothing & Fashion</li>
                                <li><i class="bi bi-check-circle text-success"></i> Food & Beverage</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <ul class="list-unstyled mb-0 small">
                                <li><i class="bi bi-check-circle text-success"></i> Home & Garden</li>
                                <li><i class="bi bi-check-circle text-success"></i> Sports & Outdoors</li>
                                <li><i class="bi bi-check-circle text-success"></i> Books & Media</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <ul class="list-unstyled mb-0 small">
                                <li><i class="bi bi-check-circle text-success"></i> Health & Beauty</li>
                                <li><i class="bi bi-check-circle text-success"></i> Toys & Games</li>
                                <li><i class="bi bi-check-circle text-success"></i> Automotive</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tips Card -->
            <div class="card border-info mt-4">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-info-circle text-info me-2"></i>
                        Tips for Category Management
                    </h6>
                    <ul class="mb-0 small">
                        <li>Use clear, concise names that describe the category's purpose</li>
                        <li>Keep descriptions informative but brief</li>
                        <li>Categories help organize products and services efficiently</li>
                        <li>Consider the hierarchy when naming categories</li>
                        <li>Mark categories as active to make them available for products</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Styles -->
<style>
    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .form-control:focus,
    .input-group:focus-within .input-group-text {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .input-group-text {
        transition: all 0.2s ease;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
        transition: color 0.2s ease;
    }

    .breadcrumb-item a:hover {
        color: #0d6efd;
    }

    .btn {
        transition: all 0.2s ease;
    }

    .btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .alert {
        border-left: 4px solid;
    }

    .alert-success {
        border-left-color: #198754;
    }

    .alert-danger {
        border-left-color: #dc3545;
    }

    .form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }
</style>

@code {
    private CategoryModel category = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Category", category);

            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Category '{category.Name}' created successfully!";

                // Reset the form
                category = new CategoryModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/category/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to create category: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding category: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/category/list");
    }
}
