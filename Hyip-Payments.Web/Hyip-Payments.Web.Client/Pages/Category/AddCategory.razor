@page "/category/add"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Category - HYIP Payments</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-folder-plus text-info"></i> Add New Category</h3>
        <ActionButton Action="Back" OnClick="GoBack">
            Back to List
        </ActionButton>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="@category" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-12">
                        <h5 class="mb-4"><i class="bi bi-info-circle"></i> Category Information</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-tag"></i> Category Name
                                <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control form-control-lg"
                                     @bind-Value="category.Name"
                                     placeholder="e.g., Electronics, Clothing, Food & Beverage" />
                            <ValidationMessage For="@(() => category.Name)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Enter a descriptive name for this category (max 100 characters)
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-file-text"></i> Description
                            </label>
                            <InputTextArea class="form-control"
                                         @bind-Value="category.Description"
                                         rows="4"
                                         placeholder="Provide a brief description of this category (optional)" />
                            <ValidationMessage For="@(() => category.Description)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Optional description to help identify what products belong in this category (max 500 characters)
                            </small>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="isActive" 
                                             class="form-check-input" 
                                             @bind-Value="category.IsActive" />
                                <label class="form-check-label fw-bold" for="isActive">
                                    <i class="bi bi-toggle-on text-success"></i> Active Category
                                </label>
                            </div>
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Only active categories can be used for products
                            </small>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-success btn-lg" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-check-circle"></i> Create Category
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Example Categories Card -->
    <div class="card shadow-sm mt-4 bg-light">
        <div class="card-body">
            <h6 class="card-title"><i class="bi bi-lightbulb text-warning"></i> Example Categories</h6>
            <div class="row">
                <div class="col-md-4">
                    <ul class="list-unstyled mb-0">
                        <li><i class="bi bi-check-circle text-success"></i> Electronics</li>
                        <li><i class="bi bi-check-circle text-success"></i> Clothing & Fashion</li>
                        <li><i class="bi bi-check-circle text-success"></i> Food & Beverage</li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <ul class="list-unstyled mb-0">
                        <li><i class="bi bi-check-circle text-success"></i> Home & Garden</li>
                        <li><i class="bi bi-check-circle text-success"></i> Sports & Outdoors</li>
                        <li><i class="bi bi-check-circle text-success"></i> Books & Media</li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <ul class="list-unstyled mb-0">
                        <li><i class="bi bi-check-circle text-success"></i> Health & Beauty</li>
                        <li><i class="bi bi-check-circle text-success"></i> Toys & Games</li>
                        <li><i class="bi bi-check-circle text-success"></i> Automotive</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CategoryModel category = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Category", category);

            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Category '{category.Name}' created successfully!";

                // Reset the form
                category = new CategoryModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/category/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to create category: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding category: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/category/list");
    }
}
