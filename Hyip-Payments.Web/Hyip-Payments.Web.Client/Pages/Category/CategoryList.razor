@page "/category/list"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Categories - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Categories</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-folder-fill text-primary me-2"></i>
                        Categories
                    </h2>
                    <p class="text-muted mb-0">Manage product categories</p>
                </div>
                <div>
                    <a href="/category/add" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Category
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Categories</h6>
                            <h3 class="mb-0">@(filteredCategories?.Count ?? 0)</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-folder-fill text-primary" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Active</h6>
                            <h3 class="mb-0">@(categories?.Count(c => c.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Inactive</h6>
                            <h3 class="mb-0">@(categories?.Count(c => !c.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-x-circle-fill text-danger" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Showing</h6>
                            <h3 class="mb-0">@paginatedCategories.Count</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-eye-fill text-info" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <!-- Search -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0" 
                               placeholder="Search categories..." 
                               @bind="searchTerm" 
                               @bind:event="oninput"
                               @onkeyup="ApplyFilters" />
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>

                <!-- Status Filter -->
                <div class="col-md-3">
                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="active">Active Only</option>
                        <option value="inactive">Inactive Only</option>
                    </select>
                </div>

                <!-- Page Size -->
                <div class="col-md-2">
                    <select class="form-select" @bind="pageSize" @bind:after="ApplyFilters">
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                </div>

                <!-- Export -->
                <div class="col-md-3 text-end">
                    <button class="btn btn-outline-success w-100" @onclick="ExportToCSV" disabled="@isLoading">
                        <i class="bi bi-file-earmark-excel me-2"></i>
                        Export CSV
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    @if (isLoading)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mb-0">Loading categories...</p>
            </div>
        </div>
    }
    else if (categories == null || !categories.Any())
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-folder-x text-muted mb-3" style="font-size: 4rem;"></i>
                <h4>No Categories Found</h4>
                <p class="text-muted mb-4">Start by creating your first category</p>
                <a href="/category/add" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>
                    Add Your First Category
                </a>
            </div>
        </div>
    }
    else if (!paginatedCategories.Any())
    {
        <!-- No Results State -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-search text-muted mb-3" style="font-size: 4rem;"></i>
                <h4>No Results Found</h4>
                <p class="text-muted mb-4">Try adjusting your search or filters</p>
                <button class="btn btn-outline-primary" @onclick="ClearFilters">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>
                    Clear Filters
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4" style="width: 50px;">
                                    <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" />
                                </th>
                                <th class="sortable" @onclick="() => SortBy(nameof(CategoryModel.Name))">
                                    Name
                                    @if (sortColumn == nameof(CategoryModel.Name))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th>Description</th>
                                <th class="sortable" @onclick="() => SortBy(nameof(CategoryModel.IsActive))">
                                    Status
                                    @if (sortColumn == nameof(CategoryModel.IsActive))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th class="text-end px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in paginatedCategories)
                            {
                                <tr>
                                    <td class="px-4">
                                        <input type="checkbox" 
                                               class="form-check-input" 
                                               @bind="category.IsSelected" />
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                                <i class="bi bi-folder-fill text-primary"></i>
                                            </div>
                                            <div>
                                                <strong>@category.Name</strong>
                                                <br />
                                                <small class="text-muted">ID: #@category.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(category.Description))
                                        {
                                            <span class="text-muted">
                                                @(category.Description.Length > 100 ? category.Description.Substring(0, 100) + "..." : category.Description)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">No description</span>
                                        }
                                    </td>
                                    <td>
                                        @if (category.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle me-1"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="btn-group" role="group">
                                            <a href="/category/edit/@category.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCategory(category.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <div class="card-footer bg-light">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="mb-0 text-muted">
                            Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, filteredCategories.Count) 
                            of @filteredCategories.Count entries
                        </p>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                                </li>
                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bulk Actions -->
        @if (categories.Any(c => c.IsSelected))
        {
            <div class="card border-0 shadow-sm mt-3 border-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@categories.Count(c => c.IsSelected) item(s) selected</strong>
                        </div>
                        <div class="btn-group">
                            <button class="btn btn-outline-success btn-sm" @onclick="BulkActivate">
                                <i class="bi bi-check-circle me-1"></i> Activate
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="BulkDeactivate">
                                <i class="bi bi-x-circle me-1"></i> Deactivate
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="BulkDelete">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }
</div>

<!-- Custom Styles -->
<style>
    .sortable {
        cursor: pointer;
        user-select: none;
    }

    .sortable:hover {
        background-color: rgba(0, 0, 0, 0.05);
    }

    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }

    .btn-group .btn {
        padding: 0.25rem 0.5rem;
    }

    .card {
        transition: all 0.3s ease;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
    }

    .breadcrumb-item a:hover {
        color: #0d6efd;
    }
</style>

@code {
    private List<CategoryModel> categories = new();
    private List<CategoryModel> filteredCategories = new();
    private List<CategoryModel> paginatedCategories = new();

    private bool isLoading = true;
    private string? errorMessage;

    // Filtering & Search
    private string searchTerm = "";
    private string statusFilter = "";

    // Sorting
    private string sortColumn = nameof(CategoryModel.Name);
    private bool sortDescending = false;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling(filteredCategories.Count / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await Http.GetFromJsonAsync<List<CategoryModel>>("api/Category");
            categories = result ?? new List<CategoryModel>();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading categories: {ex.Message}";
            categories = new List<CategoryModel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredCategories = categories.Where(c =>
            (string.IsNullOrEmpty(searchTerm) || 
             c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             (c.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) &&
            (statusFilter == "" || 
             (statusFilter == "active" && c.IsActive) || 
             (statusFilter == "inactive" && !c.IsActive))
        ).ToList();

        ApplySorting();
        currentPage = 1;
        UpdatePagination();
    }

    private void ApplySorting()
    {
        filteredCategories = sortColumn switch
        {
            nameof(CategoryModel.Name) => sortDescending 
                ? filteredCategories.OrderByDescending(c => c.Name).ToList()
                : filteredCategories.OrderBy(c => c.Name).ToList(),
            nameof(CategoryModel.IsActive) => sortDescending
                ? filteredCategories.OrderByDescending(c => c.IsActive).ToList()
                : filteredCategories.OrderBy(c => c.IsActive).ToList(),
            _ => filteredCategories
        };
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }
        ApplySorting();
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        paginatedCategories = filteredCategories
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            UpdatePagination();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        ApplyFilters();
    }

    private void ClearFilters()
    {
        searchTerm = "";
        statusFilter = "";
        ApplyFilters();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        foreach (var category in paginatedCategories)
        {
            category.IsSelected = isChecked;
        }
    }

    private async Task DeleteCategory(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this category?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Category/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await LoadCategories();
                }
                else
                {
                    errorMessage = "Failed to delete category.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting category: {ex.Message}";
            }
        }
    }

    private async Task BulkActivate()
    {
        var selected = categories.Where(c => c.IsSelected).ToList();
        foreach (var category in selected)
        {
            category.IsActive = true;
            await Http.PutAsJsonAsync($"api/Category/{category.Id}", category);
        }
        await LoadCategories();
    }

    private async Task BulkDeactivate()
    {
        var selected = categories.Where(c => c.IsSelected).ToList();
        foreach (var category in selected)
        {
            category.IsActive = false;
            await Http.PutAsJsonAsync($"api/Category/{category.Id}", category);
        }
        await LoadCategories();
    }

    private async Task BulkDelete()
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete {categories.Count(c => c.IsSelected)} categories?"))
        {
            var selected = categories.Where(c => c.IsSelected).ToList();
            foreach (var category in selected)
            {
                await Http.DeleteAsync($"api/Category/{category.Id}");
            }
            await LoadCategories();
        }
    }

    private async Task ExportToCSV()
    {
        var csv = "ID,Name,Description,Status\n";
        foreach (var category in filteredCategories)
        {
            csv += $"{category.Id},\"{category.Name}\",\"{category.Description}\",\"{(category.IsActive ? "Active" : "Inactive")}\"\n";
        }

        await JSRuntime.InvokeVoidAsync("downloadFile", "categories.csv", csv);
    }
}


