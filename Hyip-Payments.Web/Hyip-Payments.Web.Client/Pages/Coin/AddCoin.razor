@page "/coin/add"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Cryptocurrency - HYIP Payments</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-currency-bitcoin text-warning"></i> Add New Cryptocurrency</h3>
        <ActionButton Action="Back" OnClick="GoBack">
            Back to List
        </ActionButton>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="@coin" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3"><i class="bi bi-info-circle"></i> Basic Information</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-coin"></i> Coin Name
                                <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="coin.Name"
                                     placeholder="e.g., Bitcoin, Ethereum" />
                            <ValidationMessage For="@(() => coin.Name)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-tag"></i> Symbol
                                <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="coin.Symbol"
                                     placeholder="e.g., BTC, ETH"
                                     style="text-transform: uppercase;" />
                            <ValidationMessage For="@(() => coin.Symbol)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-cash-stack"></i> Current Price (USD)
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control"
                                           @bind-Value="coin.CurrentPrice"
                                           placeholder="0.00"
                                           step="0.01" />
                            </div>
                            <ValidationMessage For="@(() => coin.CurrentPrice)" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="mb-3"><i class="bi bi-gear"></i> Additional Details</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-diagram-3"></i> Network / Blockchain
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="coin.Network"
                                     placeholder="e.g., Ethereum, Binance Smart Chain" />
                            <ValidationMessage For="@(() => coin.Network)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-file-text"></i> Description
                            </label>
                            <InputTextArea class="form-control"
                                         @bind-Value="coin.Description"
                                         rows="5"
                                         placeholder="Enter coin description (optional)" />
                            <ValidationMessage For="@(() => coin.Description)" />
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-success btn-lg" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-check-circle"></i> Add Cryptocurrency
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private CoinModel coin = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Coin", coin);

            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Cryptocurrency '{coin.Name} ({coin.Symbol})' added successfully!";

                // Reset the form
                coin = new CoinModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/coin/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to add cryptocurrency: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding coin: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/coin/list");
    }
}
