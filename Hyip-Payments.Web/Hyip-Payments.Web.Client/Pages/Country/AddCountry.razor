@page "/country/add2"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Country - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/country/list">Countries</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add Country</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-globe-americas text-success me-2"></i>
                        Add New Country
                    </h2>
                    <p class="text-muted mb-0">Add a new country to your system</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-10 col-xl-8 mx-auto">
            <!-- Main Form Card -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>
                        Country Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="@country" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <!-- Left Column -->
                            <div class="col-md-6">
                                <h6 class="text-success mb-3">
                                    <i class="bi bi-flag-fill"></i> Country Information
                                </h6>

                                <!-- Country Name -->
                                <div class="mb-4">
                                    <label for="name" class="form-label fw-semibold">
                                        <i class="bi bi-flag text-success me-2"></i>
                                        Country Name
                                        <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-globe"></i>
                                        </span>
                                        <InputText id="name"
                                                 class="form-control"
                                                 @bind-Value="country.Name"
                                                 placeholder="e.g., United States, United Kingdom, Canada" />
                                    </div>
                                    <ValidationMessage For="@(() => country.Name)" class="text-danger small mt-1" />
                                    <small class="form-text text-muted">
                                        <i class="bi bi-info-circle"></i> Enter the official country name (max 100 characters)
                                    </small>
                                </div>

                                <!-- ISO Country Code -->
                                <div class="mb-4">
                                    <label for="isoCode" class="form-label fw-semibold">
                                        <i class="bi bi-code-square text-success me-2"></i>
                                        ISO Country Code
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-hash"></i>
                                        </span>
                                        <InputText id="isoCode"
                                                 class="form-control"
                                                 @bind-Value="country.IsoCode"
                                                 placeholder="e.g., USA, GBR, CAN"
                                                 maxlength="3"
                                                 style="text-transform: uppercase;" />
                                    </div>
                                    <ValidationMessage For="@(() => country.IsoCode)" class="text-danger small mt-1" />
                                    <small class="form-text text-muted">
                                        <i class="bi bi-info-circle"></i> ISO 3166-1 alpha-3 code (3 letters, uppercase)
                                    </small>
                                </div>
                            </div>

                            <!-- Right Column -->
                            <div class="col-md-6">
                                <h6 class="text-success mb-3">
                                    <i class="bi bi-geo-alt-fill"></i> Geographic Details
                                </h6>

                                <!-- Capital City -->
                                <div class="mb-4">
                                    <label for="capital" class="form-label fw-semibold">
                                        <i class="bi bi-building text-success me-2"></i>
                                        Capital City
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-star"></i>
                                        </span>
                                        <InputText id="capital"
                                                 class="form-control"
                                                 @bind-Value="country.Capital"
                                                 placeholder="e.g., Washington D.C., London, Ottawa" />
                                    </div>
                                    <ValidationMessage For="@(() => country.Capital)" class="text-danger small mt-1" />
                                    <small class="form-text text-muted">
                                        <i class="bi bi-info-circle"></i> The capital or primary city (optional)
                                    </small>
                                </div>

                                <!-- Region / Continent -->
                                <div class="mb-4">
                                    <label for="region" class="form-label fw-semibold">
                                        <i class="bi bi-map text-success me-2"></i>
                                        Region / Continent
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-compass"></i>
                                        </span>
                                        <InputSelect id="region" class="form-select" @bind-Value="country.Region">
                                            <option value="">-- Select Region --</option>
                                            <option value="Africa">🌍 Africa</option>
                                            <option value="Asia">🌏 Asia</option>
                                            <option value="Europe">🇪🇺 Europe</option>
                                            <option value="North America">🌎 North America</option>
                                            <option value="South America">🌎 South America</option>
                                            <option value="Oceania">🌊 Oceania</option>
                                            <option value="Antarctica">❄️ Antarctica</option>
                                        </InputSelect>
                                    </div>
                                    <ValidationMessage For="@(() => country.Region)" class="text-danger small mt-1" />
                                    <small class="form-text text-muted">
                                        <i class="bi bi-info-circle"></i> Select the geographic region (optional)
                                    </small>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-outline-secondary px-4" @onclick="GoBack" disabled="@isSubmitting">
                                <i class="bi bi-x-circle me-2"></i>
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-success px-4" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Adding...</span>
                                }
                                else
                                {
                                    <i class="bi bi-plus-circle me-2"></i>
                                    <span>Add Country</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

            <!-- Success/Error Messages -->
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show mt-4 shadow-sm" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div class="flex-grow-1">
                            <strong>Success!</strong>
                            <p class="mb-0">@successMessage</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-4 shadow-sm" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div class="flex-grow-1">
                            <strong>Error!</strong>
                            <p class="mb-0">@errorMessage</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
                </div>
            }

            <!-- Common Countries Reference Card -->
            <div class="card border-success mt-4">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-lightbulb text-success me-2"></i>
                        Common Country Examples
                    </h6>
                    <div class="row">
                        <div class="col-md-3">
                            <strong>North America:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>🇺🇸 United States (USA)</li>
                                <li>🇨🇦 Canada (CAN)</li>
                                <li>🇲🇽 Mexico (MEX)</li>
                            </ul>
                        </div>
                        <div class="col-md-3">
                            <strong>Europe:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>🇬🇧 United Kingdom (GBR)</li>
                                <li>🇩🇪 Germany (DEU)</li>
                                <li>🇫🇷 France (FRA)</li>
                            </ul>
                        </div>
                        <div class="col-md-3">
                            <strong>Asia:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>🇯🇵 Japan (JPN)</li>
                                <li>🇨🇳 China (CHN)</li>
                                <li>🇮🇳 India (IND)</li>
                            </ul>
                        </div>
                        <div class="col-md-3">
                            <strong>Others:</strong>
                            <ul class="list-unstyled mb-0 mt-1 small">
                                <li>🇦🇺 Australia (AUS)</li>
                                <li>🇧🇷 Brazil (BRA)</li>
                                <li>🇿🇦 South Africa (ZAF)</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tips Card -->
            <div class="card border-info mt-4">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-info-circle text-info me-2"></i>
                        Tips for Country Management
                    </h6>
                    <ul class="mb-0 small">
                        <li>Use official country names as recognized by the UN</li>
                        <li>ISO codes should follow the ISO 3166-1 alpha-3 standard</li>
                        <li>Ensure consistency in naming across all records</li>
                        <li>Capital cities help with geographic organization</li>
                        <li>Region selection aids in reporting and analytics</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Styles -->
<style>
    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .form-control:focus,
    .form-select:focus,
    .input-group:focus-within .input-group-text {
        border-color: #198754;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15);
    }

    .input-group-text {
        transition: all 0.2s ease;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
        transition: color 0.2s ease;
    }

    .breadcrumb-item a:hover {
        color: #198754;
    }

    .btn {
        transition: all 0.2s ease;
    }

    .btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .alert {
        border-left: 4px solid;
    }

    .alert-success {
        border-left-color: #198754;
    }

    .alert-danger {
        border-left-color: #dc3545;
    }
</style>

@code {
    private CountryModel country = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Country", country);

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<CountryModel>();
                successMessage = $"Country '{created?.Name}' added successfully!";

                // Reset form
                country = new CountryModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/country/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to add country: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding country: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/country/list");
    }
}
