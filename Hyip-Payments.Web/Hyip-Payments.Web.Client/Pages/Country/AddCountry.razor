@page "/country/add2"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Country - HYIP Payments</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-globe text-primary"></i> Add New Country</h3>
        <ActionButton Action="Back" OnClick="GoBack">
            Back to List
        </ActionButton>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="@country" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3"><i class="bi bi-info-circle"></i> Country Information</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-flag"></i> Country Name
                                <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control form-control-lg"
                                     @bind-Value="country.Name"
                                     placeholder="e.g., United States, United Kingdom, Canada" />
                            <ValidationMessage For="@(() => country.Name)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Enter the official country name (max 100 characters)
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-code-square"></i> ISO Country Code
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="country.IsoCode"
                                     placeholder="e.g., USA, GBR, CAN"
                                     maxlength="3"
                                     style="text-transform: uppercase;" />
                            <ValidationMessage For="@(() => country.IsoCode)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> ISO 3166-1 alpha-3 code (3 letters, optional)
                            </small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="mb-3"><i class="bi bi-geo-alt"></i> Geographic Details</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-building"></i> Capital City
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="country.Capital"
                                     placeholder="e.g., Washington D.C., London, Ottawa" />
                            <ValidationMessage For="@(() => country.Capital)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> The capital or primary city (optional)
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-map"></i> Region / Continent
                            </label>
                            <InputSelect class="form-select" @bind-Value="country.Region">
                                <option value="">-- Select Region --</option>
                                <option value="Africa">Africa</option>
                                <option value="Asia">Asia</option>
                                <option value="Europe">Europe</option>
                                <option value="North America">North America</option>
                                <option value="South America">South America</option>
                                <option value="Oceania">Oceania</option>
                                <option value="Antarctica">Antarctica</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => country.Region)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Select the geographic region (optional)
                            </small>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-success btn-lg" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-check-circle"></i> Add Country
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Common Countries Reference Card -->
    <div class="card shadow-sm mt-4 bg-light">
        <div class="card-body">
            <h6 class="card-title"><i class="bi bi-lightbulb text-warning"></i> Common Country Examples</h6>
            <div class="row">
                <div class="col-md-3">
                    <strong>North America:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>🇺🇸 United States (USA)</li>
                        <li>🇨🇦 Canada (CAN)</li>
                        <li>🇲🇽 Mexico (MEX)</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <strong>Europe:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>🇬🇧 United Kingdom (GBR)</li>
                        <li>🇩🇪 Germany (DEU)</li>
                        <li>🇫🇷 France (FRA)</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <strong>Asia:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>🇯🇵 Japan (JPN)</li>
                        <li>🇨🇳 China (CHN)</li>
                        <li>🇮🇳 India (IND)</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <strong>Others:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>🇦🇺 Australia (AUS)</li>
                        <li>🇧🇷 Brazil (BRA)</li>
                        <li>🇿🇦 South Africa (ZAF)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CountryModel country = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Country", country);

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<CountryModel>();
                successMessage = $"Country '{created?.Name}' added successfully!";

                // Reset form
                country = new CountryModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/country/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to add country: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding country: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/country/list");
    }
}
