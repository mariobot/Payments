@page "/country/list"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Countries - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Countries</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-globe text-success me-2"></i>
                        Countries
                    </h2>
                    <p class="text-muted mb-0">Manage countries and regions</p>
                </div>
                <div>
                    <a href="/country/add2" class="btn btn-success">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Country
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Countries</h6>
                            <h3 class="mb-0">@(filteredCountries?.Count ?? 0)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-globe text-success" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Regions</h6>
                            <h3 class="mb-0">@(countries?.Select(c => c.Region).Distinct().Count() ?? 0)</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-geo-alt text-info" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Active</h6>
                            <h3 class="mb-0">@(countries?.Count(c => c.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Showing</h6>
                            <h3 class="mb-0">@paginatedCountries.Count</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-eye-fill text-primary" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <!-- Search -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0" 
                               placeholder="Search countries..." 
                               @bind="searchTerm" 
                               @bind:event="oninput"
                               @onkeyup="ApplyFilters" />
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>

                <!-- Region Filter -->
                <div class="col-md-3">
                    <select class="form-select" @bind="regionFilter" @bind:after="ApplyFilters">
                        <option value="">All Regions</option>
                        @foreach (var region in countries?.Select(c => c.Region).Distinct().OrderBy(r => r) ?? Enumerable.Empty<string>())
                        {
                            <option value="@region">@region</option>
                        }
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="col-md-2">
                    <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="active">Active Only</option>
                        <option value="inactive">Inactive Only</option>
                    </select>
                </div>

                <!-- Page Size -->
                <div class="col-md-1">
                    <select class="form-select" @bind="pageSize" @bind:after="ApplyFilters">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <!-- Export -->
                <div class="col-md-2">
                    <button class="btn btn-outline-success w-100" @onclick="ExportToCSV" disabled="@isLoading">
                        <i class="bi bi-file-earmark-excel me-2"></i>
                        Export
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    @if (isLoading)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-success mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mb-0">Loading countries...</p>
            </div>
        </div>
    }
    else if (countries == null || !countries.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-globe text-muted mb-3" style="font-size: 4rem;"></i>
                <h4>No Countries Found</h4>
                <p class="text-muted mb-4">Start by adding your first country</p>
                <a href="/country/add2" class="btn btn-success">
                    <i class="bi bi-plus-circle me-2"></i>
                    Add Your First Country
                </a>
            </div>
        </div>
    }
    else if (!paginatedCountries.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-search text-muted mb-3" style="font-size: 4rem;"></i>
                <h4>No Results Found</h4>
                <p class="text-muted mb-4">Try adjusting your search or filters</p>
                <button class="btn btn-outline-success" @onclick="ClearFilters">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>
                    Clear Filters
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4" style="width: 50px;">
                                    <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" />
                                </th>
                                <th class="sortable" @onclick="() => SortBy(nameof(CountryModel.Name))">
                                    Country
                                    @if (sortColumn == nameof(CountryModel.Name))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick="() => SortBy(nameof(CountryModel.IsoCode))">
                                    ISO Code
                                    @if (sortColumn == nameof(CountryModel.IsoCode))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th>Capital</th>
                                <th class="sortable" @onclick="() => SortBy(nameof(CountryModel.Region))">
                                    Region
                                    @if (sortColumn == nameof(CountryModel.Region))
                                    {
                                        <i class="bi bi-chevron-@(sortDescending ? "down" : "up") ms-1"></i>
                                    }
                                </th>
                                <th>Status</th>
                                <th class="text-end px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var country in paginatedCountries)
                            {
                                <tr>
                                    <td class="px-4">
                                        <input type="checkbox" 
                                               class="form-check-input" 
                                               @bind="country.IsSelected" />
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-success bg-opacity-10 rounded-circle p-2 me-3">
                                                <i class="bi bi-flag-fill text-success"></i>
                                            </div>
                                            <div>
                                                <strong>@country.Name</strong>
                                                <br />
                                                <small class="text-muted">ID: #@country.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@country.IsoCode</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(country.Capital))
                                        {
                                            <span>@country.Capital</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Not specified</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">@country.Region</span>
                                    </td>
                                    <td>
                                        @if (country.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle me-1"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="btn-group" role="group">
                                            <a href="/country/edit2/@country.Id" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCountry(country.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <div class="card-footer bg-light">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="mb-0 text-muted">
                            Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, filteredCountries.Count) 
                            of @filteredCountries.Count entries
                        </p>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                                </li>
                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bulk Actions -->
        @if (countries.Any(c => c.IsSelected))
        {
            <div class="card border-0 shadow-sm mt-3 border-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@countries.Count(c => c.IsSelected) item(s) selected</strong>
                        </div>
                        <div class="btn-group">
                            <button class="btn btn-outline-success btn-sm" @onclick="BulkActivate">
                                <i class="bi bi-check-circle me-1"></i> Activate
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="BulkDeactivate">
                                <i class="bi bi-x-circle me-1"></i> Deactivate
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="BulkDelete">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }
</div>

<!-- Custom Styles -->
<style>
    .sortable {
        cursor: pointer;
        user-select: none;
    }

    .sortable:hover {
        background-color: rgba(0, 0, 0, 0.05);
    }

    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }

    .btn-group .btn {
        padding: 0.25rem 0.5rem;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
    }

    .breadcrumb-item a:hover {
        color: #198754;
    }
</style>

@code {
    private List<CountryModel> countries = new();
    private List<CountryModel> filteredCountries = new();
    private List<CountryModel> paginatedCountries = new();

    private bool isLoading = true;
    private string? errorMessage;

    // Filtering & Search
    private string searchTerm = "";
    private string statusFilter = "";
    private string regionFilter = "";

    // Sorting
    private string sortColumn = nameof(CountryModel.Name);
    private bool sortDescending = false;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling(filteredCountries.Count / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadCountries();
    }

    private async Task LoadCountries()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await Http.GetFromJsonAsync<List<CountryModel>>("api/Country");
            countries = result ?? new List<CountryModel>();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading countries: {ex.Message}";
            countries = new List<CountryModel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredCountries = countries.Where(c =>
            (string.IsNullOrEmpty(searchTerm) || 
             c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             c.IsoCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             (c.Capital?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) &&
            (statusFilter == "" || 
             (statusFilter == "active" && c.IsActive) || 
             (statusFilter == "inactive" && !c.IsActive)) &&
            (regionFilter == "" || c.Region == regionFilter)
        ).ToList();

        ApplySorting();
        currentPage = 1;
        UpdatePagination();
    }

    private void ApplySorting()
    {
        filteredCountries = sortColumn switch
        {
            nameof(CountryModel.Name) => sortDescending 
                ? filteredCountries.OrderByDescending(c => c.Name).ToList()
                : filteredCountries.OrderBy(c => c.Name).ToList(),
            nameof(CountryModel.IsoCode) => sortDescending
                ? filteredCountries.OrderByDescending(c => c.IsoCode).ToList()
                : filteredCountries.OrderBy(c => c.IsoCode).ToList(),
            nameof(CountryModel.Region) => sortDescending
                ? filteredCountries.OrderByDescending(c => c.Region).ToList()
                : filteredCountries.OrderBy(c => c.Region).ToList(),
            _ => filteredCountries
        };
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }
        ApplySorting();
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        paginatedCountries = filteredCountries
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            UpdatePagination();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        ApplyFilters();
    }

    private void ClearFilters()
    {
        searchTerm = "";
        statusFilter = "";
        regionFilter = "";
        ApplyFilters();
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        foreach (var country in paginatedCountries)
        {
            country.IsSelected = isChecked;
        }
    }

    private async Task DeleteCountry(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this country?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Country/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await LoadCountries();
                }
                else
                {
                    errorMessage = "Failed to delete country.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting country: {ex.Message}";
            }
        }
    }

    private async Task BulkActivate()
    {
        var selected = countries.Where(c => c.IsSelected).ToList();
        foreach (var country in selected)
        {
            country.IsActive = true;
            await Http.PutAsJsonAsync($"api/Country/{country.Id}", country);
        }
        await LoadCountries();
    }

    private async Task BulkDeactivate()
    {
        var selected = countries.Where(c => c.IsSelected).ToList();
        foreach (var country in selected)
        {
            country.IsActive = false;
            await Http.PutAsJsonAsync($"api/Country/{country.Id}", country);
        }
        await LoadCountries();
    }

    private async Task BulkDelete()
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete {countries.Count(c => c.IsSelected)} countries?"))
        {
            var selected = countries.Where(c => c.IsSelected).ToList();
            foreach (var country in selected)
            {
                await Http.DeleteAsync($"api/Country/{country.Id}");
            }
            await LoadCountries();
        }
    }

    private async Task ExportToCSV()
    {
        var csv = "ID,Name,ISO Code,Capital,Region,Status\n";
        foreach (var country in filteredCountries)
        {
            csv += $"{country.Id},\"{country.Name}\",\"{country.IsoCode}\",\"{country.Capital}\",\"{country.Region}\",\"{(country.IsActive ? "Active" : "Inactive")}\"\n";
        }

        await JSRuntime.InvokeVoidAsync("downloadFile", "countries.csv", csv);
    }
}

