@page "/audit-diagnostics"
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Audit Logging Diagnostics</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="bi bi-tools"></i> Audit Logging Diagnostics</h2>
            <p class="text-muted">Monitor and troubleshoot the audit logging system</p>
        </div>
    </div>

    <!-- Status Card -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card @(statusData?.HasData == true ? "border-success" : "border-warning")">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-database"></i> Database Status</h5>
                </div>
                <div class="card-body">
                    @if (isLoadingStatus)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary"></div>
                            <p>Checking database status...</p>
                        </div>
                    }
                    else if (statusData != null)
                    {
                        <div class="row">
                            <div class="col-md-3">
                                <strong>Table Exists:</strong>
                                <h4>
                                    @if (statusData.TableExists)
                                    {
                                        <span class="badge bg-success">✓ Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">✗ No</span>
                                    }
                                </h4>
                            </div>
                            <div class="col-md-3">
                                <strong>Total Records:</strong>
                                <h4><span class="badge bg-info">@statusData.TotalRecords</span></h4>
                            </div>
                            <div class="col-md-3">
                                <strong>Has Data:</strong>
                                <h4>
                                    @if (statusData.HasData)
                                    {
                                        <span class="badge bg-success">✓ Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Empty</span>
                                    }
                                </h4>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-primary" @onclick="CheckStatus">
                                    <i class="bi bi-arrow-clockwise"></i> Refresh Status
                                </button>
                            </div>
                        </div>

                        @if (statusData.LatestEntry != null)
                        {
                            <hr />
                            <h6>Latest Entry:</h6>
                            <ul class="mb-0">
                                <li><strong>ID:</strong> @statusData.LatestEntry.Id</li>
                                <li><strong>Timestamp:</strong> @statusData.LatestEntry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</li>
                                <li><strong>Action:</strong> @statusData.LatestEntry.ActionType</li>
                                <li><strong>Entity:</strong> @statusData.LatestEntry.EntityType</li>
                                <li><strong>User:</strong> @(statusData.LatestEntry.UserName ?? "System")</li>
                            </ul>
                        }

                        <hr />
                        <div class="alert @(statusData.HasData ? "alert-success" : "alert-info") mb-0">
                            <i class="bi bi-info-circle"></i> @statusData.Message
                        </div>
                    }
                    else if (statusError != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle"></i> <strong>Error:</strong> @statusError
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Actions Row -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-list"></i> View Recent Logs</h5>
                </div>
                <div class="card-body">
                    <p>Display the most recent audit log entries</p>
                    <div class="mb-3">
                        <label class="form-label">Number of records:</label>
                        <input type="number" class="form-control" @bind="recentCount" min="1" max="100" />
                    </div>
                    <button class="btn btn-info w-100 text-white" @onclick="LoadRecentLogs" disabled="@isLoadingRecent">
                        @if (isLoadingRecent)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-eye"></i> View Recent
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-trash"></i> Clear All Data</h5>
                </div>
                <div class="card-body">
                    <p>Delete all audit log records from database</p>
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> This action cannot be undone!
                        <br />
                        <small>Requires Admin role</small>
                    </div>
                    <button class="btn btn-danger w-100" @onclick="ClearData" disabled="@isClearing">
                        @if (isClearing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-trash"></i> Clear All Data
                    </button>
                    @if (clearMessage != null)
                    {
                        <div class="alert alert-info mt-3 mb-0">
                            @clearMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Logs Table -->
    @if (recentLogs != null && recentLogs.Any())
    {
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Audit Logs (@recentLogs.Count)</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Timestamp</th>
                                        <th>Action</th>
                                        <th>Entity</th>
                                        <th>Entity ID</th>
                                        <th>User</th>
                                        <th>IP</th>
                                        <th>Severity</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in recentLogs)
                                    {
                                        <tr>
                                            <td>@log.Id</td>
                                            <td><small>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</small></td>
                                            <td><span class="badge bg-primary">@log.ActionType</span></td>
                                            <td>@log.EntityType</td>
                                            <td>@log.EntityId</td>
                                            <td>@log.UserName</td>
                                            <td><small>@log.IpAddress</small></td>
                                            <td><span class="badge @GetSeverityBadge(log.Severity)">@log.Severity</span></td>
                                            <td>
                                                @if (log.IsSuccessful)
                                                {
                                                    <i class="bi bi-check-circle text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle text-danger"></i>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Quick Links -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card border-secondary">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-link-45deg"></i> Quick Links</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> <strong>To populate audit logs:</strong> Create invoices, payments, customers, or other entities. 
                        All create/update/delete operations are automatically logged.
                    </div>
                    <div class="btn-group" role="group">
                        <a href="/reports/audit-trail" class="btn btn-outline-primary">
                            <i class="bi bi-clipboard-data"></i> View Audit Trail Report
                        </a>
                        <button class="btn btn-outline-secondary" @onclick='() => NavigationManager.NavigateTo("/invoice/add")'>
                            <i class="bi bi-plus"></i> Create Invoice
                        </button>
                        <button class="btn btn-outline-secondary" @onclick='() => NavigationManager.NavigateTo("/payment/list")'>
                            <i class="bi bi-plus"></i> Create Payment
                        </button>
                        <button class="btn btn-outline-secondary" @onclick='() => NavigationManager.NavigateTo("/customer/add")'>
                            <i class="bi bi-plus"></i> Add Customer
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoadingStatus = false;
    private bool isClearing = false;
    private bool isLoadingRecent = false;

    private int recentCount = 20;

    private DatabaseStatus? statusData;
    private string? statusError;
    private string? clearMessage;
    private List<RecentLog>? recentLogs;

    protected override async Task OnInitializedAsync()
    {
        await CheckStatus();
    }

    private async Task CheckStatus()
    {
        isLoadingStatus = true;
        statusError = null;
        statusData = null;

        try
        {
            statusData = await Http.GetFromJsonAsync<DatabaseStatus>("api/AuditDiagnostics/status");
        }
        catch (Exception ex)
        {
            statusError = ex.Message;
        }
        finally
        {
            isLoadingStatus = false;
        }
    }

    private async Task ClearData()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete ALL audit log data? This cannot be undone!"))
        {
            return;
        }

        isClearing = true;
        clearMessage = null;

        try
        {
            var response = await Http.DeleteAsync("api/AuditDiagnostics/clear");
            if (response.IsSuccessStatusCode)
            {
                clearMessage = "All audit logs cleared successfully!";
                await CheckStatus();
                recentLogs = null;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                clearMessage = "Error: You must be an Admin to clear audit logs.";
            }
            else
            {
                clearMessage = $"Error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            clearMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isClearing = false;
        }
    }

    private async Task LoadRecentLogs()
    {
        isLoadingRecent = true;
        recentLogs = null;

        try
        {
            var result = await Http.GetFromJsonAsync<RecentLogsResult>($"api/AuditDiagnostics/recent?count={recentCount}");
            recentLogs = result?.RecentLogs;
        }
        catch (Exception ex)
        {
            statusError = ex.Message;
        }
        finally
        {
            isLoadingRecent = false;
        }
    }

    private string GetSeverityBadge(string severity)
    {
        return severity switch
        {
            "Critical" => "bg-danger",
            "Warning" => "bg-warning text-dark",
            "Info" => "bg-info",
            _ => "bg-secondary"
        };
    }

    // DTOs
    private class DatabaseStatus
    {
        public bool TableExists { get; set; }
        public int TotalRecords { get; set; }
        public bool HasData { get; set; }
        public LatestEntryInfo? LatestEntry { get; set; }
        public string Message { get; set; } = string.Empty;
    }

    private class LatestEntryInfo
    {
        public int Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string ActionType { get; set; } = string.Empty;
        public string EntityType { get; set; } = string.Empty;
        public string? UserName { get; set; }
    }

    private class RecentLog
    {
        public int Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string ActionType { get; set; } = string.Empty;
        public string EntityType { get; set; } = string.Empty;
        public string? EntityId { get; set; }
        public string? UserName { get; set; }
        public string? IpAddress { get; set; }
        public string Severity { get; set; } = string.Empty;
        public bool IsSuccessful { get; set; }
        public string? Description { get; set; }
    }

    private class RecentLogsResult
    {
        public int TotalCount { get; set; }
        public List<RecentLog> RecentLogs { get; set; } = new();
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}
