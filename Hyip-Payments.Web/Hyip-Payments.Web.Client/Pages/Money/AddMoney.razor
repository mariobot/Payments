@page "/addmoney2"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Add Money Transaction - HYIP Payments</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-cash-stack text-success"></i> Add Money Transaction</h3>
        <ActionButton Action="Back" OnClick="GoBack">
            Back to List
        </ActionButton>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="@money" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3"><i class="bi bi-info-circle"></i> Transaction Details</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-cash-coin"></i> Amount
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">$</span>
                                <InputNumber class="form-control"
                                           @bind-Value="money.Amount"
                                           placeholder="0.00"
                                           step="0.01" />
                            </div>
                            <ValidationMessage For="@(() => money.Amount)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Enter the transaction amount (must be greater than zero)
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-tag"></i> Transaction Slug
                                <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="money.Slug"
                                     placeholder="e.g., USD, EUR, GBP"
                                     maxlength="3"
                                     style="text-transform: uppercase;" />
                            <ValidationMessage For="@(() => money.Slug)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Short identifier (3 characters max)
                            </small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="mb-3"><i class="bi bi-globe"></i> Location & Currency</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-currency-exchange"></i> Currency Code
                                <span class="text-danger">*</span>
                            </label>
                            <InputSelect class="form-select form-select-lg" @bind-Value="money.Currency">
                                <option value="">-- Select Currency --</option>
                                <option value="USD">USD - US Dollar</option>
                                <option value="EUR">EUR - Euro</option>
                                <option value="GBP">GBP - British Pound</option>
                                <option value="JPY">JPY - Japanese Yen</option>
                                <option value="CNY">CNY - Chinese Yuan</option>
                                <option value="AUD">AUD - Australian Dollar</option>
                                <option value="CAD">CAD - Canadian Dollar</option>
                                <option value="CHF">CHF - Swiss Franc</option>
                                <option value="INR">INR - Indian Rupee</option>
                                <option value="BTC">BTC - Bitcoin</option>
                                <option value="ETH">ETH - Ethereum</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => money.Currency)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Select the currency type (3 characters)
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-geo-alt-fill"></i> Country
                                <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                     @bind-Value="money.Country"
                                     placeholder="e.g., USA, Japan, United Kingdom" />
                            <ValidationMessage For="@(() => money.Country)" />
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Enter the country name (max 100 characters)
                            </small>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-success btn-lg" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-check-circle"></i> Add Money Transaction
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Currency Reference Card -->
    <div class="card shadow-sm mt-4 bg-light">
        <div class="card-body">
            <h6 class="card-title"><i class="bi bi-lightbulb text-warning"></i> Common Currency Codes</h6>
            <div class="row">
                <div class="col-md-3">
                    <strong>Major Currencies:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>💵 USD - US Dollar</li>
                        <li>💶 EUR - Euro</li>
                        <li>💷 GBP - British Pound</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <strong>Asian Currencies:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>💴 JPY - Japanese Yen</li>
                        <li>💴 CNY - Chinese Yuan</li>
                        <li>💰 INR - Indian Rupee</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <strong>Other Currencies:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>🦘 AUD - Australian Dollar</li>
                        <li>🍁 CAD - Canadian Dollar</li>
                        <li>🏔️ CHF - Swiss Franc</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <strong>Cryptocurrencies:</strong>
                    <ul class="list-unstyled mb-0 mt-1">
                        <li>₿ BTC - Bitcoin</li>
                        <li>Ξ ETH - Ethereum</li>
                        <li>₮ USDT - Tether</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private MoneyModel money = new();
    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/money", money);

            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Money transaction of {money.Amount:C} {money.Currency} added successfully!";

                // Reset form
                money = new MoneyModel();

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/money/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to add money transaction: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error adding money: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/money/list");
    }
}
