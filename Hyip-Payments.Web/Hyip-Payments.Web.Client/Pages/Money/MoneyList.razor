@page "/money/list"
@using System.Net.Http.Json
@using Hyip_Payments.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Money - HYIP Payments</PageTitle>

<style>
    .money-card {
        transition: all 0.3s ease;
        border-left: 4px solid #ffc107;
    }
    .money-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(255, 193, 7, 0.2) !important;
    }
    .amount-badge {
        font-size: 1.1rem;
        font-weight: 600;
    }
</style>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Money</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-cash-stack text-warning me-2"></i>
                        Money Transactions
                    </h2>
                    <p class="text-muted mb-0">Manage money records and transactions</p>
                </div>
                <div>
                    <a href="/money/add" class="btn btn-warning">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Money
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Records</h6>
                            <h3 class="mb-0">@(filteredMoney?.Count ?? 0)</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-cash-stack text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Amount</h6>
                            <h3 class="mb-0 text-success">@((filteredMoney?.Sum(m => m.Amount) ?? 0).ToString("N2"))</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-currency-dollar text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Currencies</h6>
                            <h3 class="mb-0">@(filteredMoney?.Select(m => m.Currency).Distinct().Count() ?? 0)</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-coin text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Countries</h6>
                            <h3 class="mb-0">@(filteredMoney?.Select(m => m.Country).Distinct().Count() ?? 0)</h3>
                        </div>
                        <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-globe text-secondary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search by country or currency..."
                               @bind="searchTerm" @bind:after="ApplyFilters" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filterCurrency" @bind:after="ApplyFilters">
                        <option value="">All Currencies</option>
                        @foreach (var currency in allMoney?.Select(m => m.Currency).Distinct().OrderBy(c => c) ?? Enumerable.Empty<string>())
                        {
                            <option value="@currency">@currency</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="filterCountry" @bind:after="ApplyFilters">
                        <option value="">All Countries</option>
                        @foreach (var country in allMoney?.Select(m => m.Country).Distinct().OrderBy(c => c) ?? Enumerable.Empty<string>())
                        {
                            <option value="@country">@country</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="btn-group w-100" role="group">
                        <button class="btn btn-outline-secondary" @onclick="ResetFilters">
                            <i class="bi bi-x-circle me-1"></i> Reset
                        </button>
                        <button class="btn btn-outline-success" @onclick="ExportToCSV">
                            <i class="bi bi-download me-1"></i> Export CSV
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading money records...</p>
        </div>
    }
    else if (filteredMoney == null || !filteredMoney.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-cash-stack text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">No Money Records Found</h4>
                <p class="text-muted">@(string.IsNullOrEmpty(searchTerm) ? "Start by adding your first money record." : "Try adjusting your search criteria.")</p>
                @if (string.IsNullOrEmpty(searchTerm))
                {
                    <a href="/money/add" class="btn btn-warning mt-2">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add First Record
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Money Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th @onclick='() => Sort("Id")' style="cursor: pointer;">
                                    ID
                                    @if (sortColumn == "Id")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th @onclick='() => Sort("Amount")' style="cursor: pointer;" class="text-end">
                                    Amount
                                    @if (sortColumn == "Amount")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th>Currency</th>
                                <th>Slug</th>
                                <th @onclick='() => Sort("Country")' style="cursor: pointer;">
                                    Country
                                    @if (sortColumn == "Country")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th>Validation</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var money in paginatedMoney)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">#@money.Id</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="amount-badge text-success">@money.Amount.ToString("N2")</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning bg-opacity-75">@money.Currency</span>
                                    </td>
                                    <td>
                                        <span class="font-monospace">@money.Slug</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-geo-alt text-warning me-2"></i>
                                            @money.Country
                                        </div>
                                    </td>
                                    <td>
                                        @if (money.IsCurrencyValidForCountry())
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Valid
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">
                                                <i class="bi bi-exclamation-triangle me-1"></i> Check
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/money/edit/@money.Id" class="btn btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteMoney(money.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center">
                            <label class="me-2">Show:</label>
                            <select class="form-select form-select-sm w-auto" @bind="pageSize" @bind:after="UpdatePagination">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                            <span class="ms-3 text-muted">
                                Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, filteredMoney.Count) of @filteredMoney.Count records
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(1)">First</button>
                                </li>
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                                </li>
                                @for (int pageNum = Math.Max(1, currentPage - 2); pageNum <= Math.Min(totalPages, currentPage + 2); pageNum++)
                                {
                                    var pageNumber = pageNum;
                                    <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                </li>
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(totalPages)">Last</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<MoneyModel>? allMoney;
    private List<MoneyModel>? filteredMoney;
    private List<MoneyModel> paginatedMoney = new();
    private bool isLoading = true;
    private string? errorMessage;

    // Search and Filter
    private string searchTerm = "";
    private string filterCurrency = "";
    private string filterCountry = "";

    // Sorting
    private string sortColumn = "Id";
    private bool sortAscending = true;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadMoney();
    }

    private async Task LoadMoney()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var response = await Http.GetAsync("api/money");
            if (response.IsSuccessStatusCode)
            {
                allMoney = await response.Content.ReadFromJsonAsync<List<MoneyModel>>() ?? new();
                ApplyFilters();
            }
            else
            {
                errorMessage = $"Error loading money list (Status: {(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("showToast", "Error loading money records", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        if (allMoney == null) return;

        filteredMoney = allMoney.Where(m =>
            (string.IsNullOrEmpty(searchTerm) ||
             m.Country.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             m.Currency.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             m.Slug.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(filterCurrency) || m.Currency == filterCurrency) &&
            (string.IsNullOrEmpty(filterCountry) || m.Country == filterCountry)
        ).ToList();

        ApplySorting();
        UpdatePagination();
    }

    private void ApplySorting()
    {
        if (filteredMoney == null) return;

        filteredMoney = sortColumn switch
        {
            "Id" => sortAscending ? filteredMoney.OrderBy(m => m.Id).ToList() : filteredMoney.OrderByDescending(m => m.Id).ToList(),
            "Amount" => sortAscending ? filteredMoney.OrderBy(m => m.Amount).ToList() : filteredMoney.OrderByDescending(m => m.Amount).ToList(),
            "Country" => sortAscending ? filteredMoney.OrderBy(m => m.Country).ToList() : filteredMoney.OrderByDescending(m => m.Country).ToList(),
            _ => filteredMoney.OrderBy(m => m.Id).ToList()
        };
    }

    private void Sort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplySorting();
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        if (filteredMoney == null) return;

        totalPages = (int)Math.Ceiling(filteredMoney.Count / (double)pageSize);
        currentPage = Math.Min(currentPage, Math.Max(1, totalPages));

        paginatedMoney = filteredMoney
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ChangePage(int page)
    {
        currentPage = page;
        UpdatePagination();
    }

    private void ResetFilters()
    {
        searchTerm = "";
        filterCurrency = "";
        filterCountry = "";
        ApplyFilters();
    }

    private async Task DeleteMoney(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this money record?");
        if (!confirmed) return;

        try
        {
            await Http.DeleteAsync($"api/money/{id}");
            await JSRuntime.InvokeVoidAsync("showToast", "Money record deleted successfully", "success");
            await LoadMoney();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
        }
    }

    private async Task ExportToCSV()
    {
        if (filteredMoney == null || !filteredMoney.Any()) return;

        var csv = "ID,Amount,Currency,Slug,Country,Valid\n";
        foreach (var money in filteredMoney)
        {
            csv += $"{money.Id},{money.Amount},\"{money.Currency}\",\"{money.Slug}\",\"{money.Country}\",{(money.IsCurrencyValidForCountry() ? "Yes" : "No")}\n";
        }

        await JSRuntime.InvokeVoidAsync("downloadFile", "money.csv", csv);
        await JSRuntime.InvokeVoidAsync("showToast", "CSV exported successfully", "success");
    }
}

