@page "/product/edit/{Id:int}"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Edit Product - HYIP Payments</PageTitle>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/product/list">Products</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Product</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-box-seam text-orange me-2"></i>
                        Edit Product
                    </h2>
                    <p class="text-muted mb-0">Update product information</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <!-- Loading State -->
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div class="spinner-border text-orange mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mb-0">Loading product details...</p>
            </div>
        </div>
    }
    else if (product == null)
    {
        <!-- Not Found State -->
        <div class="card shadow-sm border-orange">
            <div class="card-body text-center py-5">
                <i class="bi bi-exclamation-triangle text-orange" style="font-size: 3rem;"></i>
                <h4 class="mt-3">Product Not Found</h4>
                <p class="text-muted">The product you're looking for doesn't exist or has been deleted.</p>
                <button class="btn btn-orange mt-3" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Return to Products
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-10 col-xl-8 mx-auto">
                <!-- Main Form Card -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-orange text-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-pencil-square me-2"></i>
                            Product Information
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <EditForm Model="@product" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />

                            <!-- Product ID Display -->
                            <div class="alert alert-light border mb-4">
                                <div class="row">
                                    <div class="col-sm-4">
                                        <small class="text-muted">Product ID</small>
                                    </div>
                                    <div class="col-sm-8">
                                        <strong>#@product.Id</strong>
                                    </div>
                                </div>
                            </div>

                            <!-- Basic Information Section -->
                            <div class="mb-4">
                                <h6 class="text-orange mb-3">
                                    <i class="bi bi-info-circle-fill"></i> Basic Information
                                </h6>

                                <div class="row">
                                    <!-- Product Name -->
                                    <div class="col-md-12 mb-4">
                                        <label for="name" class="form-label fw-semibold">
                                            <i class="bi bi-box text-orange me-2"></i>
                                            Product Name
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-tag-fill"></i>
                                            </span>
                                            <InputText id="name"
                                                     class="form-control"
                                                     @bind-Value="product.Name"
                                                     placeholder="e.g., iPhone 15 Pro, Nike Air Max" />
                                        </div>
                                        <ValidationMessage For="@(() => product.Name)" class="text-danger small mt-1" />
                                        <small class="form-text text-muted">
                                            <i class="bi bi-info-circle"></i> Enter a descriptive product name
                                        </small>
                                    </div>

                                    <!-- Description -->
                                    <div class="col-md-12 mb-4">
                                        <label for="description" class="form-label fw-semibold">
                                            <i class="bi bi-text-paragraph text-orange me-2"></i>
                                            Description
                                        </label>
                                        <InputTextArea id="description"
                                                      class="form-control"
                                                      @bind-Value="product.Description"
                                                      rows="4"
                                                      placeholder="Enter detailed product description (optional)" />
                                        <ValidationMessage For="@(() => product.Description)" class="text-danger small mt-1" />
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <small class="form-text text-muted">
                                                <i class="bi bi-info-circle"></i> Detailed product description
                                            </small>
                                            <small class="text-muted">
                                                @((product.Description?.Length ?? 0))/1000 characters
                                            </small>
                                        </div>
                                    </div>

                                    <!-- Price -->
                                    <div class="col-md-12 mb-4">
                                        <label for="price" class="form-label fw-semibold">
                                            <i class="bi bi-cash-stack text-orange me-2"></i>
                                            Price
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group input-group-lg">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-currency-dollar"></i>
                                            </span>
                                            <InputNumber id="price"
                                                       class="form-control"
                                                       @bind-Value="product.Price"
                                                       placeholder="0.00"
                                                       step="0.01" />
                                        </div>
                                        <ValidationMessage For="@(() => product.Price)" class="text-danger small mt-1" />
                                        <small class="form-text text-muted">
                                            <i class="bi bi-info-circle"></i> Product price in USD
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <!-- Classification Section -->
                            <div class="mb-4">
                                <h6 class="text-orange mb-3">
                                    <i class="bi bi-tags-fill"></i> Classification
                                </h6>

                                <div class="row">
                                    <!-- Category -->
                                    <div class="col-md-6 mb-4">
                                        <label for="category" class="form-label fw-semibold">
                                            <i class="bi bi-folder text-orange me-2"></i>
                                            Category
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-grid"></i>
                                            </span>
                                            <InputSelect id="category" class="form-select" @bind-Value="product.CategoryId">
                                                <option value="0">-- Select Category --</option>
                                                @if (categories != null)
                                                {
                                                    @foreach (var category in categories)
                                                    {
                                                        <option value="@category.Id">@category.Name</option>
                                                    }
                                                }
                                            </InputSelect>
                                        </div>
                                        <ValidationMessage For="@(() => product.CategoryId)" class="text-danger small mt-1" />
                                        <small class="form-text text-muted">
                                            <i class="bi bi-info-circle"></i> Select product category
                                        </small>
                                    </div>

                                    <!-- Brand -->
                                    <div class="col-md-6 mb-4">
                                        <label for="brand" class="form-label fw-semibold">
                                            <i class="bi bi-award text-orange me-2"></i>
                                            Brand
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-bookmark"></i>
                                            </span>
                                            <InputSelect id="brand" class="form-select" @bind-Value="product.BrandId">
                                                <option value="0">-- Select Brand --</option>
                                                @if (brands != null)
                                                {
                                                    @foreach (var brand in brands)
                                                    {
                                                        <option value="@brand.Id">@brand.Name</option>
                                                    }
                                                }
                                            </InputSelect>
                                        </div>
                                        <ValidationMessage For="@(() => product.BrandId)" class="text-danger small mt-1" />
                                        <small class="form-text text-muted">
                                            <i class="bi bi-info-circle"></i> Select product brand
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <!-- Status Section -->
                            <div class="mb-4">
                                <h6 class="text-orange mb-3">
                                    <i class="bi bi-toggle-on"></i> Status
                                </h6>

                                <div class="form-check form-switch">
                                    <InputCheckbox id="isActive"
                                                 class="form-check-input"
                                                 @bind-Value="product.IsActive"
                                                 style="width: 3em; height: 1.5em;" />
                                    <label class="form-check-label fw-semibold ms-2" for="isActive">
                                        @if (product.IsActive)
                                        {
                                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                                            <span class="text-success">Product is Active</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle-fill text-secondary me-2"></i>
                                            <span class="text-secondary">Product is Inactive</span>
                                        }
                                    </label>
                                </div>
                                <small class="form-text text-muted ms-5">
                                    <i class="bi bi-info-circle"></i> Active products are visible in the system
                                </small>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-outline-secondary px-4" @onclick="GoBack" disabled="@isSubmitting">
                                    <i class="bi bi-x-circle me-2"></i>
                                    Cancel
                                </button>
                                <button type="submit" class="btn btn-orange px-4" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        <span>Updating...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle me-2"></i>
                                        <span>Update Product</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>

                <!-- Success/Error Messages -->
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show mt-4 shadow-sm" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
                            <div class="flex-grow-1">
                                <strong>Success!</strong>
                                <p class="mb-0">@successMessage</p>
                            </div>
                        </div>
                        <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show mt-4 shadow-sm" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
                            <div class="flex-grow-1">
                                <strong>Error!</strong>
                                <p class="mb-0">@errorMessage</p>
                            </div>
                        </div>
                        <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
                    </div>
                }

                <!-- Tips Card -->
                <div class="card border-info mt-4">
                    <div class="card-body">
                        <h6 class="card-title">
                            <i class="bi bi-lightbulb text-info me-2"></i>
                            Tips for Product Management
                        </h6>
                        <ul class="mb-0 small">
                            <li>Keep product information up-to-date</li>
                            <li>Ensure prices reflect current market values</li>
                            <li>Update descriptions when features change</li>
                            <li>Verify category and brand assignments</li>
                            <li>Deactivate discontinued products</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Custom Styles -->
<style>
    .text-orange {
        color: #fd7e14 !important;
    }

    .bg-orange {
        background-color: #fd7e14 !important;
    }

    .btn-orange {
        background-color: #fd7e14;
        border-color: #fd7e14;
        color: white;
    }

    .btn-orange:hover:not(:disabled) {
        background-color: #e36d0d;
        border-color: #e36d0d;
    }

    .border-orange {
        border-color: #fd7e14 !important;
    }

    .spinner-border.text-orange {
        color: #fd7e14 !important;
    }

    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .form-control:focus,
    .form-select:focus,
    .input-group:focus-within .input-group-text {
        border-color: #fd7e14;
        box-shadow: 0 0 0 0.25rem rgba(253, 126, 20, 0.15);
    }

    .input-group-text {
        transition: all 0.2s ease;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #6c757d;
        transition: color 0.2s ease;
    }

    .breadcrumb-item a:hover {
        color: #fd7e14;
    }

    .btn {
        transition: all 0.2s ease;
    }

    .btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .alert {
        border-left: 4px solid;
    }

    .alert-success {
        border-left-color: #198754;
    }

    .alert-danger {
        border-left-color: #dc3545;
    }

    .form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }
</style>
                                    <label class="form-check-label fw-semibold" for="isActive">
                                        Product is Active
                                    </label>
                                    <div class="form-text">Active products are visible in the system</div>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                                <button type="button" class="btn btn-outline-secondary" @onclick="GoBack" disabled="@isSubmitting">
                                    <i class="bi bi-x-circle me-1"></i> Cancel
                                </button>
                                <button type="submit" class="btn btn-warning" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        <span>Updating...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle me-1"></i>
                                        <span>Update Product</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductModel? product;
    private List<CategoryModel>? categories;
    private List<BrandModel>? brands;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Load product, categories, and brands in parallel
            var productTask = Http.GetFromJsonAsync<ProductModel>($"api/Product/{Id}");
            var categoriesTask = Http.GetFromJsonAsync<List<CategoryModel>>("api/Category");
            var brandsTask = Http.GetFromJsonAsync<List<BrandModel>>("api/Brand");

            await Task.WhenAll(productTask, categoriesTask, brandsTask);

            product = await productTask;
            categories = await categoriesTask;
            brands = await brandsTask;

            if (product == null)
            {
                errorMessage = "Product not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
            Console.WriteLine($"Error loading product: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/Product/{Id}", product);

            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Product '{product!.Name}' updated successfully!";

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/product/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to update product: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error updating product: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/product/list");
    }
}
    }
}
