@page "/recurring-invoice/list"
@using Hyip_Payments.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Recurring Invoices</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-arrow-repeat text-primary"></i> Recurring Invoices</h2>
        <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/recurring-invoice/add"))">
            <i class="bi bi-plus-circle"></i> Create Template
        </button>
    </div>

    <!-- Filters -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Customer</label>
                    <select class="form-select" @bind="filterCustomerId" @bind:after="LoadRecurringInvoices">
                        <option value="">All Customers</option>
                        @foreach (var customer in customers)
                        {
                            <option value="@customer.Id">@customer.CompanyName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Frequency</label>
                    <select class="form-select" @bind="filterFrequency" @bind:after="LoadRecurringInvoices">
                        <option value="">All Frequencies</option>
                        <option value="Monthly">Monthly</option>
                        <option value="Quarterly">Quarterly</option>
                        <option value="Annually">Annually</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="filterStatus" @bind:after="LoadRecurringInvoices">
                        <option value="">All</option>
                        <option value="active">Active Only</option>
                        <option value="inactive">Inactive Only</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                        <i class="bi bi-x-circle"></i> Clear Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading recurring invoices...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else if (!recurringInvoices.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox display-1 d-block mb-3"></i>
            <h4>No Recurring Invoices</h4>
            <p class="text-muted">Create your first recurring invoice template to automate billing</p>
            <button class="btn btn-primary mt-3" @onclick="@(() => Navigation.NavigateTo("/recurring-invoice/add"))">
                <i class="bi bi-plus-circle"></i> Create Template
            </button>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-list"></i> Recurring Invoice Templates (@recurringInvoices.Count)
                </h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Template Name</th>
                            <th>Customer</th>
                            <th>Frequency</th>
                            <th>Day of Month</th>
                            <th>Next Generation</th>
                            <th>Generated</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in recurringInvoices)
                        {
                            <tr>
                                <td>
                                    <strong>@item.TemplateName</strong>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <br />
                                        <small class="text-muted">@item.Description</small>
                                    }
                                </td>
                                <td>
                                    <a href="/customer/view/@item.CustomerId" class="text-decoration-none">
                                        @item.Customer?.CompanyName
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-@GetFrequencyColor(item.Frequency)">
                                        <i class="bi bi-@GetFrequencyIcon(item.Frequency)"></i> @item.Frequency
                                    </span>
                                </td>
                                <td class="text-center">@GetDayOfMonthDisplay(item.DayOfMonth)</td>
                                <td>
                                    @if (item.NextGenerationDate.HasValue)
                                    {
                                        <span class="@GetNextDateClass(item.NextGenerationDate.Value)">
                                            @item.NextGenerationDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                        @if (IsDueForGeneration(item.NextGenerationDate.Value))
                                        {
                                            <span class="badge bg-warning text-dark ms-1">Due Now</span>
                                        }
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-info">@item.GeneratedInvoiceCount</span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-pause-circle"></i> Inactive
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="@(() => Navigation.NavigateTo($"/recurring-invoice/view/{item.Id}"))">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo($"/recurring-invoice/edit/{item.Id}"))">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-success" @onclick="@(() => GenerateInvoice(item.Id))" disabled="@(!item.IsActive || isGenerating)">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick="@(() => ShowDeleteConfirm(item))">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
@if (deleteConfirmItem != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this recurring invoice template?</p>
                    <p class="fw-bold">@deleteConfirmItem.TemplateName</p>
                    <p class="text-muted">This will NOT delete invoices already generated from this template.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Delete Template
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RecurringInvoiceModel> recurringInvoices = new();
    private List<CustomerModel> customers = new();
    private bool isLoading = true;
    private bool isGenerating = false;
    private bool isDeleting = false;
    private string? errorMessage;
    private RecurringInvoiceModel? deleteConfirmItem;

    // Filters
    private string filterCustomerId = "";
    private string filterFrequency = "";
    private string filterStatus = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
        await LoadRecurringInvoices();
    }

    private async Task LoadCustomers()
    {
        try
        {
            customers = await Http.GetFromJsonAsync<List<CustomerModel>>("api/Customer?isActive=true") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
        }
    }

    private async Task LoadRecurringInvoices()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var url = "api/RecurringInvoice?";
            
            if (!string.IsNullOrEmpty(filterCustomerId))
                url += $"customerId={filterCustomerId}&";
            
            if (!string.IsNullOrEmpty(filterFrequency))
                url += $"frequency={filterFrequency}&";
            
            if (!string.IsNullOrEmpty(filterStatus))
                url += $"isActive={filterStatus == "active"}&";

            recurringInvoices = await Http.GetFromJsonAsync<List<RecurringInvoiceModel>>(url) ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading recurring invoices: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearFilters()
    {
        filterCustomerId = "";
        filterFrequency = "";
        filterStatus = "";
        await LoadRecurringInvoices();
    }

    private async Task GenerateInvoice(int recurringInvoiceId)
    {
        if (!confirm("Generate an invoice from this template now?"))
            return;

        isGenerating = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsync($"api/RecurringInvoice/{recurringInvoiceId}/generate", null);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<dynamic>();
                Navigation.NavigateTo($"/invoice/view/{result?.invoiceId}");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to generate invoice: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
            await LoadRecurringInvoices();
        }
    }

    private void ShowDeleteConfirm(RecurringInvoiceModel item)
    {
        deleteConfirmItem = item;
    }

    private void CancelDelete()
    {
        deleteConfirmItem = null;
    }

    private async Task ConfirmDelete()
    {
        if (deleteConfirmItem == null) return;

        isDeleting = true;

        try
        {
            var response = await Http.DeleteAsync($"api/RecurringInvoice/{deleteConfirmItem.Id}");

            if (response.IsSuccessStatusCode)
            {
                recurringInvoices.Remove(deleteConfirmItem);
                deleteConfirmItem = null;
            }
            else
            {
                errorMessage = "Failed to delete recurring invoice";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private string GetFrequencyColor(string frequency)
    {
        return frequency.ToLower() switch
        {
            "monthly" => "primary",
            "quarterly" => "info",
            "annually" => "success",
            _ => "secondary"
        };
    }

    private string GetFrequencyIcon(string frequency)
    {
        return frequency.ToLower() switch
        {
            "monthly" => "calendar-month",
            "quarterly" => "calendar3",
            "annually" => "calendar-year",
            _ => "calendar"
        };
    }

    private string GetDayOfMonthDisplay(int day)
    {
        return day switch
        {
            1 => "1st",
            2 => "2nd",
            3 => "3rd",
            21 => "21st",
            22 => "22nd",
            23 => "23rd",
            31 => "31st",
            _ => $"{day}th"
        };
    }

    private bool IsDueForGeneration(DateTime nextDate)
    {
        return nextDate.Date <= DateTime.UtcNow.Date;
    }

    private string GetNextDateClass(DateTime nextDate)
    {
        if (IsDueForGeneration(nextDate))
            return "text-danger fw-bold";
        else if ((nextDate - DateTime.UtcNow).Days <= 7)
            return "text-warning fw-bold";
        else
            return "";
    }

    private bool confirm(string message)
    {
        // In real implementation, use JSInterop for confirm dialog
        return true;
    }
}
