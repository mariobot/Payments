@page "/user/list"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Users - HYIP Payments</PageTitle>

<style>
    .user-card {
        transition: all 0.3s ease;
        border-left: 4px solid #6c757d;
    }
    .user-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(108, 117, 125, 0.2) !important;
    }
</style>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Users</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-people-fill text-secondary me-2"></i>
                        Users
                    </h2>
                    <p class="text-muted mb-0">Manage system users and permissions</p>
                </div>
                <div>
                    <button class="btn btn-secondary" @onclick="CreateUser">
                        <i class="bi bi-plus-circle me-2"></i>
                        Create New User
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Users</h6>
                            <h3 class="mb-0">@(filteredUsers?.Count ?? 0)</h3>
                        </div>
                        <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-people-fill text-secondary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Active Users</h6>
                            <h3 class="mb-0 text-success">@(filteredUsers?.Count(u => u.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Inactive Users</h6>
                            <h3 class="mb-0 text-warning">@(filteredUsers?.Count(u => !u.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-x-circle text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">New This Month</h6>
                            <h3 class="mb-0 text-info">@(filteredUsers?.Count(u => u.CreatedAt.Month == DateTime.UtcNow.Month && u.CreatedAt.Year == DateTime.UtcNow.Year) ?? 0)</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-person-plus text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search by username, email, or name..."
                               @bind="searchTerm" @bind:after="ApplyFilters" />
                    </div>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="filterStatus" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="sortBy" @bind:after="ApplyFilters">
                        <option value="created_desc">Newest First</option>
                        <option value="created_asc">Oldest First</option>
                        <option value="username">Username (A-Z)</option>
                        <option value="email">Email (A-Z)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="btn-group w-100" role="group">
                        <button class="btn btn-outline-secondary" @onclick="ResetFilters">
                            <i class="bi bi-x-circle me-1"></i> Reset
                        </button>
                        <button class="btn btn-outline-success" @onclick="ExportToCSV">
                            <i class="bi bi-download me-1"></i> Export CSV
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    @if (users == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-secondary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading users...</p>
        </div>
    }
    else if (filteredUsers == null || !filteredUsers.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">No Users Found</h4>
                <p class="text-muted">@(string.IsNullOrEmpty(searchTerm) ? "Start by creating your first user." : "Try adjusting your search criteria.")</p>
                @if (string.IsNullOrEmpty(searchTerm))
                {
                    <button class="btn btn-secondary mt-2" @onclick="CreateUser">
                        <i class="bi bi-plus-circle me-2"></i>
                        Create First User
                    </button>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Users Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th @onclick='() => Sort("Id")' style="cursor: pointer;">
                                    ID
                                    @if (sortColumn == "Id")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th @onclick='() => Sort("Username")' style="cursor: pointer;">
                                    Username
                                    @if (sortColumn == "Username")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th @onclick='() => Sort("Email")' style="cursor: pointer;">
                                    Email
                                    @if (sortColumn == "Email")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th>Full Name</th>
                                <th @onclick='() => Sort("CreatedAt")' style="cursor: pointer;">
                                    Created At
                                    @if (sortColumn == "CreatedAt")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in paginatedUsers)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">#@user.Id</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-circle text-secondary me-2 fs-5"></i>
                                            <strong>@user.Username</strong>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="mailto:@user.Email" class="text-decoration-none">
                                            <i class="bi bi-envelope me-1"></i>
                                            @user.Email
                                        </a>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(user.FirstName) || !string.IsNullOrEmpty(user.LastName))
                                        {
                                            <span>@user.FirstName @user.LastName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar me-1"></i>
                                            @user.CreatedAt.ToString("MMM dd, yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle me-1"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => ViewUser(user.Id)" title="View">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-warning" @onclick="() => EditUser(user.Id)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-secondary" @onclick="() => ChangePassword(user.Id)" title="Change Password">
                                                <i class="bi bi-key"></i>
                                            </button>
                                            <button class="btn @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                                    @onclick="() => ToggleUserStatus(user.Id)" 
                                                    title="@(user.IsActive ? "Deactivate" : "Activate")">
                                                <i class="bi bi-toggle-@(user.IsActive ? "on" : "off")"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteUser(user.Id)" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center">
                            <label class="me-2">Show:</label>
                            <select class="form-select form-select-sm w-auto" @bind="pageSize" @bind:after="UpdatePagination">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                            <span class="ms-3 text-muted">
                                Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, filteredUsers.Count) of @filteredUsers.Count users
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(1)">First</button>
                                </li>
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                                </li>
                                @for (int pageNum = Math.Max(1, currentPage - 2); pageNum <= Math.Min(totalPages, currentPage + 2); pageNum++)
                                {
                                    var pageNumber = pageNum;
                                    <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                </li>
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(totalPages)">Last</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<UserModel>? users;
    private List<UserModel>? filteredUsers;
    private List<UserModel> paginatedUsers = new();
    private string? message;

    // Search and Filter
    private string searchTerm = "";
    private string filterStatus = "";
    private string sortBy = "created_desc";

    // Sorting
    private string sortColumn = "CreatedAt";
    private bool sortAscending = false;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            users = await Http.GetFromJsonAsync<List<UserModel>>("api/User") ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            message = $"Error loading users: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("showToast", "Error loading users", "error");
        }
    }

    private void ApplyFilters()
    {
        if (users == null) return;

        filteredUsers = users.Where(u =>
            (string.IsNullOrEmpty(searchTerm) ||
             u.Username.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             u.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             (u.FirstName != null && u.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
             (u.LastName != null && u.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))) &&
            (string.IsNullOrEmpty(filterStatus) ||
             (filterStatus == "active" && u.IsActive) ||
             (filterStatus == "inactive" && !u.IsActive))
        ).ToList();

        ApplySorting();
        UpdatePagination();
    }

    private void ApplySorting()
    {
        if (filteredUsers == null) return;

        filteredUsers = sortColumn switch
        {
            "Id" => sortAscending ? filteredUsers.OrderBy(u => u.Id).ToList() : filteredUsers.OrderByDescending(u => u.Id).ToList(),
            "Username" => sortAscending ? filteredUsers.OrderBy(u => u.Username).ToList() : filteredUsers.OrderByDescending(u => u.Username).ToList(),
            "Email" => sortAscending ? filteredUsers.OrderBy(u => u.Email).ToList() : filteredUsers.OrderByDescending(u => u.Email).ToList(),
            "CreatedAt" => sortAscending ? filteredUsers.OrderBy(u => u.CreatedAt).ToList() : filteredUsers.OrderByDescending(u => u.CreatedAt).ToList(),
            _ => filteredUsers.OrderByDescending(u => u.CreatedAt).ToList()
        };
    }

    private void Sort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplySorting();
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        if (filteredUsers == null) return;

        totalPages = (int)Math.Ceiling(filteredUsers.Count / (double)pageSize);
        currentPage = Math.Min(currentPage, Math.Max(1, totalPages));

        paginatedUsers = filteredUsers
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ChangePage(int page)
    {
        currentPage = page;
        UpdatePagination();
    }

    private void ResetFilters()
    {
        searchTerm = "";
        filterStatus = "";
        sortBy = "created_desc";
        ApplyFilters();
    }

    private void CreateUser()
    {
        NavigationManager.NavigateTo("/user/add");
    }

    private void ViewUser(int id)
    {
        NavigationManager.NavigateTo($"/user/view/{id}");
    }

    private void EditUser(int id)
    {
        NavigationManager.NavigateTo($"/user/edit/{id}");
    }

    private void ChangePassword(int id)
    {
        NavigationManager.NavigateTo($"/user/change-password/{id}");
    }

    private async Task ToggleUserStatus(int id)
    {
        try
        {
            var response = await Http.PutAsync($"api/User/toggle-active/{id}", null);
            if (response.IsSuccessStatusCode)
            {
                message = "User status updated successfully!";
                await JSRuntime.InvokeVoidAsync("showToast", "User status updated successfully", "success");
                await LoadUsers();
            }
            else
            {
                message = "Failed to update user status.";
                await JSRuntime.InvokeVoidAsync("showToast", "Failed to update user status", "error");
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
        }
    }

    private async Task DeleteUser(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this user?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/User/{id}");
                if (response.IsSuccessStatusCode)
                {
                    message = "User deleted successfully!";
                    await JSRuntime.InvokeVoidAsync("showToast", "User deleted successfully", "success");
                    await LoadUsers();
                }
                else
                {
                    message = "Failed to delete user.";
                    await JSRuntime.InvokeVoidAsync("showToast", "Failed to delete user", "error");
                }
            }
            catch (Exception ex)
            {
                message = $"Error: {ex.Message}";
                await JSRuntime.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
            }
        }
    }

    private async Task ExportToCSV()
    {
        if (filteredUsers == null || !filteredUsers.Any()) return;

        var csv = "ID,Username,Email,First Name,Last Name,Created At,Status\n";
        foreach (var user in filteredUsers)
        {
            csv += $"{user.Id},\"{user.Username}\",\"{user.Email}\",\"{user.FirstName}\",\"{user.LastName}\",\"{user.CreatedAt:yyyy-MM-dd}\",{(user.IsActive ? "Active" : "Inactive")}\n";
        }

        await JSRuntime.InvokeVoidAsync("downloadFile", "users.csv", csv);
        await JSRuntime.InvokeVoidAsync("showToast", "CSV exported successfully", "success");
    }
}


