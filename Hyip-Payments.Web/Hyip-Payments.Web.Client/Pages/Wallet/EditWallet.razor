@page "/wallet/edit/{Id:int}"
@rendermode InteractiveAuto
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Edit Wallet - HYIP Payments</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-pencil-square text-warning"></i> Edit Wallet</h3>
        <ActionButton Action="Back" OnClick="GoBack">
            Back to List
        </ActionButton>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading wallet...</p>
        </div>
    }
    else if (wallet == null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i> Wallet not found
        </div>
    }
    else
    {
        @if (errorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
            </div>
        }

        @if (successMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i> @successMessage
                <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <EditForm Model="@wallet" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />

                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="mb-3"><i class="bi bi-info-circle"></i> Wallet Information</h5>

                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-geo-alt"></i> Wallet Address
                                    <span class="text-danger">*</span>
                                </label>
                                <InputText class="form-control"
                                         @bind-Value="wallet.Address"
                                         placeholder="e.g., 0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb" />
                                <ValidationMessage For="@(() => wallet.Address)" />
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Enter the blockchain wallet address
                                </small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-currency-exchange"></i> Currency / Coin Type
                                    <span class="text-danger">*</span>
                                </label>
                                <InputText class="form-control"
                                         @bind-Value="wallet.Currency"
                                         placeholder="e.g., BTC, ETH, USDT"
                                         maxlength="32"
                                         style="text-transform: uppercase;" />
                                <ValidationMessage For="@(() => wallet.Currency)" />
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> The cryptocurrency type (BTC, ETH, USDT, etc.)
                                </small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h5 class="mb-3"><i class="bi bi-cash-stack"></i> Balance & Status</h5>

                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-cash"></i> Balance
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <InputNumber class="form-control"
                                               @bind-Value="wallet.Balance"
                                               placeholder="0.00"
                                               step="0.01" />
                                </div>
                                <ValidationMessage For="@(() => wallet.Balance)" />
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Current balance in USD equivalent
                                </small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-person-badge"></i> User ID (Optional)
                                </label>
                                <InputText class="form-control"
                                         @bind-Value="wallet.UserId"
                                         placeholder="User identifier" />
                                <ValidationMessage For="@(() => wallet.UserId)" />
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Link this wallet to a specific user
                                </small>
                            </div>

                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <InputCheckbox id="isActive" 
                                                 class="form-check-input" 
                                                 @bind-Value="wallet.IsActive" />
                                    <label class="form-check-label fw-bold" for="isActive">
                                        <i class="bi bi-toggle-on"></i> Active Wallet
                                    </label>
                                </div>
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Enable this wallet for transactions
                                </small>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary" @onclick="GoBack">
                            <i class="bi bi-x-circle"></i> Cancel
                        </button>
                        <button type="submit" class="btn btn-warning btn-lg" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            <i class="bi bi-check-circle"></i> Update Wallet
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private WalletModel? wallet;
    private string? successMessage;
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadWallet();
    }

    private async Task LoadWallet()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            wallet = await Http.GetFromJsonAsync<WalletModel>($"api/wallet/{Id}");
            if (wallet == null)
            {
                errorMessage = "Wallet not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading wallet: {ex.Message}";
            Console.WriteLine($"Error loading wallet: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/wallet/{Id}", wallet);

            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Wallet for {wallet!.Currency} updated successfully!";

                // Redirect after short delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/wallet/list");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to update wallet: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error updating wallet: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/wallet/list");
    }
}
