@page "/wallet/list"
@using Hyip_Payments.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Wallets - HYIP Payments</PageTitle>

<style>
    .wallet-card {
        transition: all 0.3s ease;
        border-left: 4px solid #0dcaf0;
    }
    .wallet-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(13, 202, 240, 0.2) !important;
    }
    .balance-badge {
        font-size: 1.1rem;
        font-weight: 600;
    }
</style>

<div class="container-fluid px-4 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Wallets</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-wallet2 text-info me-2"></i>
                        Wallets
                    </h2>
                    <p class="text-muted mb-0">Manage cryptocurrency wallets</p>
                </div>
                <div>
                    <a href="/wallet/add" class="btn btn-info">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Wallet
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Wallets</h6>
                            <h3 class="mb-0">@(filteredWallets?.Count ?? 0)</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-wallet2 text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Active Wallets</h6>
                            <h3 class="mb-0 text-success">@(filteredWallets?.Count(w => w.IsActive) ?? 0)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Balance</h6>
                            <h3 class="mb-0 text-info">@totalBalance.ToString("N2")</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-currency-dollar text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Currencies</h6>
                            <h3 class="mb-0">@(filteredWallets?.Select(w => w.Currency).Distinct().Count() ?? 0)</h3>
                        </div>
                        <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-coin text-secondary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search by address or currency..."
                               @bind="searchTerm" @bind:after="ApplyFilters" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filterCurrency" @bind:after="ApplyFilters">
                        <option value="">All Currencies</option>
                        @foreach (var currency in allWallets?.Select(w => w.Currency).Distinct().OrderBy(c => c) ?? Enumerable.Empty<string>())
                        {
                            <option value="@currency">@currency</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="filterStatus" @bind:after="ApplyFilters">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="btn-group w-100" role="group">
                        <button class="btn btn-outline-secondary" @onclick="ResetFilters">
                            <i class="bi bi-x-circle me-1"></i> Reset
                        </button>
                        <button class="btn btn-outline-success" @onclick="ExportToCSV">
                            <i class="bi bi-download me-1"></i> Export CSV
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading wallets...</p>
        </div>
    }
    else if (filteredWallets == null || !filteredWallets.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-wallet2 text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">No Wallets Found</h4>
                <p class="text-muted">@(string.IsNullOrEmpty(searchTerm) ? "Start by adding your first wallet." : "Try adjusting your search criteria.")</p>
                @if (string.IsNullOrEmpty(searchTerm))
                {
                    <a href="/wallet/add" class="btn btn-info mt-2">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add First Wallet
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Wallets Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th @onclick='() => Sort("Address")' style="cursor: pointer;">
                                    Address
                                    @if (sortColumn == "Address")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th @onclick='() => Sort("Currency")' style="cursor: pointer;">
                                    Currency
                                    @if (sortColumn == "Currency")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th @onclick='() => Sort("Balance")' style="cursor: pointer;" class="text-end">
                                    Balance
                                    @if (sortColumn == "Balance")
                                    {
                                        <i class="bi bi-@(sortAscending ? "sort-up" : "sort-down")"></i>
                                    }
                                </th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var wallet in paginatedWallets)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-wallet2 text-info me-2"></i>
                                            <span class="font-monospace">@wallet.Address</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info bg-opacity-75">@wallet.Currency</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="balance-badge text-success">@wallet.Balance.ToString("N8")</span>
                                    </td>
                                    <td>
                                        @if (wallet.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle me-1"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@wallet.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/wallet/edit/@wallet.Id" class="btn btn-outline-info">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteWallet(wallet.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center">
                            <label class="me-2">Show:</label>
                            <select class="form-select form-select-sm w-auto" @bind="pageSize" @bind:after="UpdatePagination">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                            <span class="ms-3 text-muted">
                                Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, filteredWallets.Count) of @filteredWallets.Count wallets
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(1)">First</button>
                                </li>
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                                </li>
                                @for (int pageNum = Math.Max(1, currentPage - 2); pageNum <= Math.Min(totalPages, currentPage + 2); pageNum++)
                                {
                                    var pageNumber = pageNum;
                                    <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                </li>
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(totalPages)">Last</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<WalletModel>? allWallets;
    private List<WalletModel>? filteredWallets;
    private List<WalletModel> paginatedWallets = new();
    private bool isLoading = true;
    private string? errorMessage;

    // Search and Filter
    private string searchTerm = "";
    private string filterCurrency = "";
    private string filterStatus = "";

    // Sorting
    private string sortColumn = "CreatedAt";
    private bool sortAscending = false;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;

    // Stats
    private decimal totalBalance => filteredWallets?.Sum(w => w.Balance) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadWallets();
    }

    private async Task LoadWallets()
    {
        try
        {
            isLoading = true;
            allWallets = await Http.GetFromJsonAsync<List<WalletModel>>("api/wallet") ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            await JSRuntime.InvokeVoidAsync("showToast", "Error loading wallets", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        if (allWallets == null) return;

        filteredWallets = allWallets.Where(w =>
            (string.IsNullOrEmpty(searchTerm) ||
             w.Address.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             w.Currency.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(filterCurrency) || w.Currency == filterCurrency) &&
            (string.IsNullOrEmpty(filterStatus) ||
             (filterStatus == "active" && w.IsActive) ||
             (filterStatus == "inactive" && !w.IsActive))
        ).ToList();

        ApplySorting();
        UpdatePagination();
    }

    private void ApplySorting()
    {
        if (filteredWallets == null) return;

        filteredWallets = sortColumn switch
        {
            "Address" => sortAscending ? filteredWallets.OrderBy(w => w.Address).ToList() : filteredWallets.OrderByDescending(w => w.Address).ToList(),
            "Currency" => sortAscending ? filteredWallets.OrderBy(w => w.Currency).ToList() : filteredWallets.OrderByDescending(w => w.Currency).ToList(),
            "Balance" => sortAscending ? filteredWallets.OrderBy(w => w.Balance).ToList() : filteredWallets.OrderByDescending(w => w.Balance).ToList(),
            _ => sortAscending ? filteredWallets.OrderBy(w => w.CreatedAt).ToList() : filteredWallets.OrderByDescending(w => w.CreatedAt).ToList()
        };
    }

    private void Sort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplySorting();
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        if (filteredWallets == null) return;

        totalPages = (int)Math.Ceiling(filteredWallets.Count / (double)pageSize);
        currentPage = Math.Min(currentPage, Math.Max(1, totalPages));

        paginatedWallets = filteredWallets
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ChangePage(int page)
    {
        currentPage = page;
        UpdatePagination();
    }

    private void ResetFilters()
    {
        searchTerm = "";
        filterCurrency = "";
        filterStatus = "";
        ApplyFilters();
    }

    private async Task DeleteWallet(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this wallet?");
        if (!confirmed) return;

        try
        {
            await Http.DeleteAsync($"api/wallet/{id}");
            await JSRuntime.InvokeVoidAsync("showToast", "Wallet deleted successfully", "success");
            await LoadWallets();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
        }
    }

    private async Task ExportToCSV()
    {
        if (filteredWallets == null || !filteredWallets.Any()) return;

        var csv = "Address,Currency,Balance,Status,Created\n";
        foreach (var wallet in filteredWallets)
        {
            csv += $"\"{wallet.Address}\",\"{wallet.Currency}\",{wallet.Balance},{(wallet.IsActive ? "Active" : "Inactive")},\"{wallet.CreatedAt:yyyy-MM-dd}\"\n";
        }

        await JSRuntime.InvokeVoidAsync("downloadFile", "wallets.csv", csv);
        await JSRuntime.InvokeVoidAsync("showToast", "CSV exported successfully", "success");
    }
}
